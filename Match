Sub MergeAllSheetsFromFiles()
    Dim wsDestOCAOCR As Worksheet, wsDestSOLVA As Worksheet, wsDestETUDEINC As Worksheet
    Dim wbSource As Workbook, wsSource As Worksheet
    Dim lastRow As Long, lastCol As Long, formatCol As Long
    Dim destRowOCAOCR As Long, destRowSOLVA As Long, destRowETUDEINC As Long
    Dim i As Long
    Dim fso As Object, folder As Object, subfolder As Object, fichier As Object
    Dim basePath As String
    Dim sheetNames As Variant
    Dim sheetIndex As Integer
    Dim headerCopied As Boolean   ' per sheet tracking

    basePath = "\\uf11pu01\COFIDIS_TC\A-PRODUCTION\1-PRODUCTION\CC DFRA\2-Nouveau répertoire"

    ' Set destination sheets (master workbook)
    Set wsDestOCAOCR = ThisWorkbook.Worksheets("OCAOCR")
    Set wsDestSOLVA = ThisWorkbook.Worksheets("SOLVA")
    Set wsDestETUDEINC = ThisWorkbook.Worksheets("ETUDEINC")

    ' Clear all destination sheets
    wsDestOCAOCR.Cells.Clear
    wsDestSOLVA.Cells.Clear
    wsDestETUDEINC.Cells.Clear

    ' Initialize destination row pointers (row 1 is header, data starts at row 2)
    destRowOCAOCR = 2
    destRowSOLVA = 2
    destRowETUDEINC = 2

    ' File system object
    Set fso = CreateObject("Scripting.FileSystemObject")
    Set folder = fso.GetFolder(basePath)

    ' Loop through subfolders and files
    For Each subfolder In folder.SubFolders
        For Each fichier In subfolder.Files
            ' Skip temporary files
            If Left(fichier.Name, 2) = "~$" Then GoTo NEXTFICHIER

            ' Open the source workbook
            Set wbSource = Workbooks.Open(basePath & "\" & subfolder.Name & "\Cofidis.xlsm")

            ' Process each of the three sheets
            For sheetIndex = 0 To 2
                Select Case sheetIndex
                    Case 0
                        Set wsSource = Nothing
                        On Error Resume Next
                        Set wsSource = wbSource.Worksheets("OCAOCR")
                        On Error GoTo 0
                        If wsSource Is Nothing Then GoTo NextSheet
                        ' Copy header if destination is empty
                        If wsDestOCAOCR.Cells(1, 1).Value = "" Then
                            wsSource.Rows(1).Copy wsDestOCAOCR.Rows(1)
                        End If
                        ' Find column "i"
                        formatCol = 0
                        lastCol = wsSource.Cells(1, wsSource.Columns.Count).End(xlToLeft).Column
                        For i = 1 To lastCol
                            If LCase(wsSource.Cells(1, i).Value) = "i" Then
                                formatCol = i
                                Exit For
                            End If
                        Next i
                        If formatCol > 0 Then
                            lastRow = wsSource.Cells(wsSource.Rows.Count, 1).End(xlUp).Row
                            For i = 2 To lastRow
                                If InStr(1, LCase(wsSource.Cells(i, formatCol).Value)) > 0 Then
                                    wsSource.Rows(i).Copy wsDestOCAOCR.Rows(destRowOCAOCR)
                                    destRowOCAOCR = destRowOCAOCR + 1
                                End If
                            Next i
                        Else
                            ' Optional: log missing column, but continue
                        End If

                    Case 1
                        Set wsSource = Nothing
                        On Error Resume Next
                        Set wsSource = wbSource.Worksheets("SOLVA")
                        On Error GoTo 0
                        If wsSource Is Nothing Then GoTo NextSheet
                        If wsDestSOLVA.Cells(1, 1).Value = "" Then
                            wsSource.Rows(1).Copy wsDestSOLVA.Rows(1)
                        End If
                        formatCol = 0
                        lastCol = wsSource.Cells(1, wsSource.Columns.Count).End(xlToLeft).Column
                        For i = 1 To lastCol
                            If LCase(wsSource.Cells(1, i).Value) = "i" Then
                                formatCol = i
                                Exit For
                            End If
                        Next i
                        If formatCol > 0 Then
                            lastRow = wsSource.Cells(wsSource.Rows.Count, 1).End(xlUp).Row
                            For i = 2 To lastRow
                                If InStr(1, LCase(wsSource.Cells(i, formatCol).Value)) > 0 Then
                                    wsSource.Rows(i).Copy wsDestSOLVA.Rows(destRowSOLVA)
                                    destRowSOLVA = destRowSOLVA + 1
                                End If
                            Next i
                        End If

                    Case 2
                        Set wsSource = Nothing
                        On Error Resume Next
                        Set wsSource = wbSource.Worksheets("ETUDEINC")
                        On Error GoTo 0
                        If wsSource Is Nothing Then GoTo NextSheet
                        If wsDestETUDEINC.Cells(1, 1).Value = "" Then
                            wsSource.Rows(1).Copy wsDestETUDEINC.Rows(1)
                        End If
                        formatCol = 0
                        lastCol = wsSource.Cells(1, wsSource.Columns.Count).End(xlToLeft).Column
                        For i = 1 To lastCol
                            If LCase(wsSource.Cells(1, i).Value) = "i" Then
                                formatCol = i
                                Exit For
                            End If
                        Next i
                        If formatCol > 0 Then
                            lastRow = wsSource.Cells(wsSource.Rows.Count, 1).End(xlUp).Row
                            For i = 2 To lastRow
                                If InStr(1, LCase(wsSource.Cells(i, formatCol).Value)) > 0 Then
                                    wsSource.Rows(i).Copy wsDestETUDEINC.Rows(destRowETUDEINC)
                                    destRowETUDEINC = destRowETUDEINC + 1
                                End If
                            Next i
                        End If
                End Select
NextSheet:
            Next sheetIndex

            ' Close the source workbook
            wbSource.Close SaveChanges:=False

NEXTFICHIER:
        Next fichier
    Next subfolder

    MsgBox "Data merged successfully from all files.", vbInformation
End Sub
