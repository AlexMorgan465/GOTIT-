Sub MatchAndCopy()

    Dim ws1 As Worksheet
    Dim ws2 As Worksheet
    Dim lastRow1 As Long
    Dim lastRow2 As Long
    Dim i As Long, j As Long
    
    ' Define sheets
    Set ws1 = ThisWorkbook.Sheets("SHEET_TRACE_NAME")
    Set ws2 = ThisWorkbook.Sheets("NC_LOG_ACTIONS")
    
    ' Get last rows
    lastRow1 = ws1.Cells(ws1.Rows.Count, "A").End(xlUp).row
    lastRow2 = ws2.Cells(ws2.Rows.Count, "C").End(xlUp).row
    
    ' Loop through Sheet1 column A
    For i = 1 To lastRow1
        
        ' Loop through Sheet2 column C
        For j = 1 To lastRow2
            
            ' Compare values
            If ws1.Cells(i, 1).Value = ws2.Cells(j, 3).Value Then
                
    MsgBox ws2.Cells(j, 5).Value
        parts = Split(ws2.Cells(j, 5).Value, "?")
        status = Trim(parts(UBound(parts)))
        MsgBox status
        
   
                ' Copy Column E from Sheet2 ? put in Column B of Sheet1
                ws1.Cells(i, 5).Value = status
                ws1.Cells(i, 8).Value = ws2.Cells(j, 1).Value
                ws1.Cells(i, 11).Value = ws1.Cells(i, 8).Value - ws1.Cells(i, 7).Value
                
                Exit For ' Stop searching once match is found
                
            End If
            
        Next j
        
    Next i

    MsgBox "Done!"

End Sub
