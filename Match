Private Sub cmb_Sauvegarder_Click()

    Dim wx As Worksheet
    Set wx = ThisWorkbook.Worksheets("extraction")
    
    Dim lastRow As Long, i As Long
    lastRow = wx.Cells(wx.Rows.Count, 1).End(xlUp).Row
    
    If lastRow < 2 Then
        MsgBox "Aucune donnée à sauvegarder.", vbExclamation
        Exit Sub
    End If

    Dim userName As String
    userName = Environ("USERNAME")
    
    Dim ligneDate As String
    Dim moisLigne As String, anneeLigne As String
    Dim filePath As String
    Dim ligneCSV As String
    
    Dim fileDict As Object
    Set fileDict = CreateObject("Scripting.Dictionary")
    
    Dim fileNum As Integer
    
    Dim nbExport As Long
    nbExport = 0

    For i = 2 To lastRow
        
        ligneDate = wx.Cells(i, 2).Value ' colonne B
        
        If ligneDate <> "" Then
            
            ' Extraire mois et année depuis "dd/mm/yyyy"
            moisLigne = Mid(ligneDate, 4, 2)
            anneeLigne = Mid(ligneDate, 7, 4)
            
            ' Construire chemin fichier
            filePath = "\\uf11pu01\ACCESSIBILITÉ_CONSEILLERS\" & _
                       userName & "_" & moisLigne & "_" & anneeLigne & ".csv"
            
            ' Ouvrir fichier UNE SEULE FOIS par mois
            If Not fileDict.exists(filePath) Then
                fileNum = FreeFile
                Open filePath For Append As #fileNum
                fileDict.Add filePath, fileNum
            End If
            
            fileNum = fileDict(filePath)
            
            ' Construire ligne CSV
            ligneCSV = wx.Cells(i, 1).Value & ";" & _
                       wx.Cells(i, 2).Value & ";" & _
                       wx.Cells(i, 3).Value & ";" & _
                       wx.Cells(i, 4).Value & ";" & _
                       wx.Cells(i, 5).Value & ";" & _
                       wx.Cells(i, 6).Value & ";" & _
                       wx.Cells(i, 7).Value & ";" & _
                       wx.Cells(i, 8).Value & ";" & _
                       wx.Cells(i, 9).Value & ";" & _
                       wx.Cells(i, 10).Value
            
            Print #fileNum, ligneCSV
            nbExport = nbExport + 1
            
        End If
        
    Next i

    ' Fermer tous les fichiers ouverts
    Dim key As Variant
    For Each key In fileDict.Keys
        Close #fileDict(key)
    Next key
    
    wx.Rows("2:" & wx.Rows.Count).ClearContents
    
    MsgBox nbExport & " ligne(s) sauvegardée(s) dans les fichiers mensuels.", vbInformation

End Sub

Private Sub cmb_Supprimmer_Click()

    If vue.ListIndex < 0 Then
        MsgBox "Veuillez sélectionner une ligne à supprimer.", vbExclamation
        Exit Sub
    End If

    Dim ws As Worksheet
    Set ws = ThisWorkbook.Worksheets("temp")

    Dim selectedValue As String
    Dim i As Long, lastRow As Long

    selectedValue = vue.List(vue.ListIndex, 2)

    lastRow = ws.Cells(ws.Rows.Count, 1).End(xlUp).Row

    For i = 2 To lastRow
        If ws.Cells(i, 3).Value = selectedValue Then
            ws.Rows(i).Delete
            Exit For
        End If
    Next i

    MsgBox "Ligne supprimée avec succès.", vbInformation

    lastRow = ws.Cells(ws.Rows.Count, 1).End(xlUp).Row

    If lastRow >= 2 Then
        vue.List = ws.Range("A2:I" & lastRow).Value
    Else
        vue.Clear
    End If
    
    Call log


End Sub


