Private Sub LoadFichiers()
    Dim path As String
    
    lstFichiers.Clear
    
    If cmbDomaine = "" Or cmbSousDomaine = "" Or cmbStatutSource = "" Then Exit Sub
    
    ' Construire le chemin selon la structure
    Dim structType As StructureType
    structType = GetDomainStructure(cmbDomaine.Value)
            
    Select Case cmbDomaine.Value
        Case "Bouygues telecom", "CIC CIB ASSET SERVICING"
            path = ROOT_PATH & "\" & cmbDomaine.Value & "\" & cmbStatutSource.Value
            
        Case "ACM"
            path = ROOT_PATH & "\" & cmbDomaine.Value & "\" & _
                   cmbSousDomaine.Value & "\" & cmbStatutSource.Value
        
        Case "DIRCO"
            path = ROOT_PATH & "\" & cmbDomaine.Value & "\" & _
                   cmbSousDomaine.Value & "\" & "FICHES CLIENTS" & "\" & cmbStatutSource.Value
            
        Case THREE_LEVEL
            If cmbStatutSource.Value = "A TRAITER" Then
                path = ROOT_PATH & "\" & cmbDomaine.Value & "\A TRAITER\" & cmbSousDomaine.Value
            ElseIf cmbStatutSource.Value = "EN COURS" Then
                path = ROOT_PATH & "\" & cmbDomaine.Value & "\EN COURS\" & cmbSousDomaine.Value
            End If
    End Select
    
    MsgBox path
    ' Charger les fichiers
    If FolderExists(path) Then
        LoadFilesToList lstFichiers, path
    Else
        lstFichiers.AddItem "[DOSSIER VIDE]"
    End If
End Sub
Private Sub cmdDeplacer_Click()
    Dim srcPath As String, dstPath As String
    Dim fileName As String
    Dim ws As Worksheet
    Dim row As Long
    
    ' Validation
    If lstFichiers.ListIndex = -1 Or lstFichiers.Value = "[DOSSIER VIDE]" Then
        MsgBox "Sélectionnez un fichier", vbExclamation
        Exit Sub
    End If
    
    If txtAgent = "" Then
        MsgBox "Agent requis", vbCritical
        Exit Sub
    End If
    
    fileName = lstFichiers.Value
    
    ' Construire les chemins
    Dim structType As StructureType
    structType = GetDomainStructure(cmbDomaine.Value)
    
    ' Source
    Select Case structType
        Case "Bouygues telecom", "CIC CIB ASSET SERVICING"
            srcPath = ROOT_PATH & "\" & cmbDomaine & "\" & "A TRAITER"
            
        Case "ACM"
            srcPath = ROOT_PATH & "\" & cmbDomaine & "\" & _
                     cmbSousDomaine & "\" & "A TRAITER"
                    
        Case "DIRCO"
            srcPath = ROOT_PATH & "\" & cmbDomaine & "\" & _
                     cmbSousDomaine & "\" & "A TRAITER"
            
        Case THREE_LEVEL
            If Label6.Caption = "A TRAITER" Then
                srcPath = ROOT_PATH & "\" & cmbDomaine & "\A TRAITER\" & cmbSousDomaine
            Else
                srcPath = ROOT_PATH & "\" & cmbDomaine & "\" & "A TRAITER"
            End If
    End Select
    
    srcPath = srcPath & "\" & fileName
    
    ' Destination
    Select Case structType
        Case SIMPLE
            dstPath = ROOT_PATH & "\" & cmbDomaine & "\" & "EN COURS"
            
        Case Complex
            dstPath = ROOT_PATH & "\" & cmbDomaine & "\" & _
                     cmbSousDomaine & "\" & "EN COURS"
            
        Case THREE_LEVEL
            If Label6.Caption = "A TRAITER" Then
                dstPath = ROOT_PATH & "\" & cmbDomaine & "\EN COURS\" & cmbSousDomaine
            Else
                dstPath = ROOT_PATH & "\" & cmbDomaine & "\" & "EN COURS"
            End If
    End Select
    
    ' Créer dossier si besoin
    CreateFolderIfNotExists dstPath
    dstPath = dstPath & "\" & fileName
    
    ' Déplacer
    Name srcPath As dstPath
    
    ' Mettre à jour traçabilité
    Set ws = ThisWorkbook.Sheets("SHEET_TRACE_NAME")
    row = GetTraceRow(ws, fileName)
    
    ' Journaliser
       LogAction "Déplacement", fileName, cmbDomaine.Value, cmbSousDomaine.Value, txtAgent, txtCommentaire.Value, _
              cmbStatutSource & " ? " & cmbStatutDestination
    
    ' Recharger
    LoadFichiers
    txtCommentaire.Value = ""
    
    MsgBox "? Fichier déplacé avec succès !", vbInformation
End Sub

