Private Sub cmb_Sauvegarder_Click()

    Dim ws As Worksheet
    Set ws = ThisWorkbook.Worksheets("extraction")
    
    Dim lastRow As Long, i As Long
    lastRow = ws.Cells(ws.Rows.Count, 1).End(xlUp).Row
    
    If lastRow < 2 Then
        MsgBox "Aucune donnée à sauvegarder.", vbExclamation
        Exit Sub
    End If
    
    ' Infos fichier
    Dim userName As String
    Dim mois As String, annee As String
    
    userName = Environ("USERNAME")
    mois = Format(Date, "mm")
    annee = Format(Date, "yyyy")
    
    Dim filePath As String
    filePath = "\\uf11pu01\Accessibilité_conseiller\" & userName & "_" & mois & "_" & annee & ".csv"
    
    Dim fileNum As Integer
    fileNum = FreeFile
    
    ' Ouvrir fichier (Append si existe, sinon créer)
    Open filePath For Append As #fileNum
    
    Dim ligneCSV As String
    Dim ligneDate As Date
    
    For i = 2 To lastRow
        
        ' Vérifier si la ligne correspond au mois actuel
        If IsDate(ws.Cells(i, 2).Value) Then
            ligneDate = ws.Cells(i, 2).Value
            
            If Month(ligneDate) = Month(Date) And Year(ligneDate) = Year(Date) Then
                
                ' Construire ligne CSV
                ligneCSV = ws.Cells(i, 1).Value & ";" & _
                           ws.Cells(i, 2).Value & ";" & _
                           ws.Cells(i, 3).Value & ";" & _
                           ws.Cells(i, 4).Value & ";" & _
                           ws.Cells(i, 5).Value & ";" & _
                           ws.Cells(i, 6).Value & ";" & _
                           ws.Cells(i, 7).Value & ";" & _
                           ws.Cells(i, 8).Value & ";" & _
                           ws.Cells(i, 9).Value & ";" & _
                           ws.Cells(i, 10).Value
                
                ' Écrire dans fichier
                Print #fileNum, ligneCSV
                
            End If
        End If
        
    Next i
    
    Close #fileNum
    
    MsgBox "Sauvegarde effectuée avec succès.", vbInformation

End Sub
