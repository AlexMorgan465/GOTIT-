<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Crédit Mutuel | Tableau de Bord des Extractions UserForm</title>
    <!-- Google Fonts + Font Awesome Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <!-- SheetJS & Chart.js -->
    <script src="https://cdn.sheetjs.com/xlsx-0.20.2/package/dist/xlsx.full.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: #f0f4f9;
            color: #1a2c3e;
            padding: 32px 28px;
        }

        .dashboard-container {
            max-width: 1600px;
            margin: 0 auto;
        }

        .bank-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            flex-wrap: wrap;
            margin-bottom: 30px;
            border-bottom: 3px solid #0066a1;
            padding-bottom: 18px;
        }
        .title-section h1 {
            font-size: 1.85rem;
            font-weight: 600;
            color: #003366;
            letter-spacing: -0.3px;
        }
        .title-section p {
            color: #4a627a;
            font-weight: 500;
            font-size: 0.9rem;
            margin-top: 6px;
        }
        .credit-mutuel-badge {
            background: #ffffffcc;
            backdrop-filter: blur(2px);
            padding: 8px 20px;
            border-radius: 40px;
            font-weight: 600;
            font-size: 0.9rem;
            color: #0066a1;
            border: 1px solid #cddfe7;
            box-shadow: 0 2px 6px rgba(0,0,0,0.02);
        }
        .credit-mutuel-badge i {
            margin-right: 8px;
            color: #ff7e33;
        }

        .upload-card {
            background: white;
            border-radius: 28px;
            box-shadow: 0 8px 20px rgba(0, 51, 102, 0.08);
            padding: 22px 28px;
            margin-bottom: 36px;
            transition: all 0.2s;
            border: 1px solid #e2edf2;
        }
        .upload-area {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            justify-content: space-between;
            gap: 20px;
        }
        .file-label {
            background: #f0f6fa;
            border: 1px dashed #0066a1;
            border-radius: 48px;
            padding: 12px 28px;
            font-weight: 500;
            cursor: pointer;
            color: #0066a1;
            transition: 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 12px;
        }
        .file-label:hover {
            background: #e6f0f5;
            border-color: #004b7c;
        }
        .file-label i {
            font-size: 1.2rem;
        }
        #fileInput {
            display: none;
        }
        .info-msg {
            color: #2c6979;
            background: #eef5f8;
            padding: 8px 20px;
            border-radius: 40px;
            font-size: 0.85rem;
        }
        .error-msg {
            background: #ffe8e6;
            color: #b13e3e;
            padding: 12px 20px;
            border-radius: 20px;
            margin-top: 16px;
            font-size: 0.85rem;
            display: inline-block;
        }

        .kpi-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
            gap: 20px;
            margin-bottom: 40px;
        }
        .kpi-card {
            background: white;
            border-radius: 28px;
            padding: 20px 18px;
            box-shadow: 0 5px 14px rgba(0, 0, 0, 0.03);
            transition: transform 0.1s ease, box-shadow 0.2s;
            border: 1px solid #e7edf2;
        }
        .kpi-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 14px 26px rgba(0, 51, 102, 0.08);
            border-color: #cbdde6;
        }
        .kpi-title {
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-weight: 600;
            color: #5b7a9a;
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .kpi-value {
            font-size: 2.4rem;
            font-weight: 700;
            color: #003366;
            line-height: 1.2;
        }
        .kpi-sub {
            font-size: 0.75rem;
            color: #6b8aac;
            margin-top: 8px;
            border-top: 1px solid #eef2f5;
            padding-top: 6px;
        }

        .charts-section {
            margin-top: 20px;
        }
        .section-title {
            font-size: 1.3rem;
            font-weight: 600;
            color: #1e4663;
            margin: 30px 0 18px 0;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .charts-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(480px, 1fr));
            gap: 28px;
            margin-bottom: 30px;
        }
        .chart-card {
            background: white;
            border-radius: 28px;
            padding: 18px 20px 20px 20px;
            box-shadow: 0 8px 18px rgba(0, 0, 0, 0.04);
            transition: all 0.2s;
            border: 1px solid #e2eef4;
        }
        .chart-card h3 {
            font-weight: 600;
            font-size: 1.1rem;
            margin-bottom: 16px;
            color: #1f4e79;
            display: flex;
            align-items: center;
            gap: 8px;
            border-left: 4px solid #ff7e33;
            padding-left: 12px;
        }
        canvas {
            max-height: 280px;
            width: 100%;
        }
        .empty-chart-placeholder {
            text-align: center;
            padding: 40px;
            color: #8fa4bc;
            font-style: italic;
        }
        footer {
            text-align: center;
            margin-top: 45px;
            font-size: 0.75rem;
            color: #7f9abb;
            border-top: 1px solid #dae9f0;
            padding-top: 24px;
        }
        @media (max-width: 760px) {
            body { padding: 20px 16px; }
            .charts-grid { grid-template-columns: 1fr; }
            .kpi-value { font-size: 1.8rem; }
        }
        .badge-blue {
            background: #eef2fc;
            border-radius: 40px;
            padding: 4px 12px;
            font-size: 0.7rem;
            font-weight: 500;
        }
    </style>
</head>
<body>
<div class="dashboard-container">
    <div class="bank-header">
        <div class="title-section">
            <h1><i class="fas fa-chart-line" style="color:#0066a1; margin-right: 12px;"></i>Tableau de bord extractions UserForm</h1>
            <p>Analyse des performances collaborateurs · Suivi des traitements · Données feuille "DATA"</p>
        </div>
        <div class="credit-mutuel-badge">
            <i class="fas fa-university"></i> Crédit Mutuel · Digital KPI
        </div>
    </div>

    <div class="upload-card">
        <div class="upload-area">
            <div>
                <label for="fileInput" class="file-label">
                    <i class="fas fa-file-excel"></i> Importer un fichier Excel (.xlsx, .xls)
                </label>
                <input type="file" id="fileInput" accept=".xlsx, .xls, .csv" />
                <div style="margin-top: 12px;">
                    <span class="info-msg"><i class="fas fa-info-circle"></i> La feuille doit s'appeler <strong>DATA</strong> avec les colonnes : NomFichier, Domaine, SousDomaine, Statut, Status_2, Date_A_TRAITER, Date_FIN, Date_de_Retraitement, Agent, <strong>Temps unitaire</strong> (optionnel mais recommandé pour le graphique dédié)</span>
                </div>
            </div>
            <i class="fas fa-chart-pie" style="font-size: 2rem; color: #8eb9d0; opacity: 0.7;"></i>
        </div>
        <div id="uploadFeedback"></div>
    </div>

    <!-- KPIs dynamiques -->
    <div id="kpiContainer" class="kpi-grid"></div>

    <div class="charts-section" id="chartsArea" style="display: none;">
        <div class="section-title"><i class="fas fa-chart-simple"></i> Indicateurs visuels & performances</div>
        <div class="charts-grid">
            <div class="chart-card"><h3><i class="fas fa-chart-pie"></i> Répartition par Statut</h3><canvas id="statusPieChart" width="400" height="280"></canvas></div>
            <div class="chart-card"><h3><i class="fas fa-chart-bar"></i> Top domaines d'activité</h3><canvas id="domainBarChart" width="400" height="280"></canvas></div>
            <div class="chart-card"><h3><i class="fas fa-calendar-week"></i> Évolution mensuelle (soumissions)</h3><canvas id="timelineChart" width="400" height="280"></canvas></div>
            <div class="chart-card"><h3><i class="fas fa-user-tie"></i> Top 8 collaborateurs (agents)</h3><canvas id="agentBarChart" width="400" height="280"></canvas></div>
            <div class="chart-card"><h3><i class="fas fa-stopwatch"></i> Temps unitaire moyen par Domaine</h3><canvas id="domainDurationChart" width="400" height="280"></canvas></div>
            <div class="chart-card"><h3><i class="fas fa-layer-group"></i> Sous-Domaine (top 7)</h3><canvas id="subdomainChart" width="400" height="280"></canvas></div>
        </div>
    </div>
    <footer>
        <i class="fas fa-chart-line"></i> KPIs temps réel · Extraction UserForm · L'engagement mutualiste
    </footer>
</div>

<script>
    // Variables pour stocker les graphiques et les détruire avant reconstruction
    let charts = {
        status: null,
        domain: null,
        timeline: null,
        agent: null,
        domainDuration: null,   // désormais affiche la moyenne du temps unitaire par domaine
        subdomain: null
    };

    // Fonction utilitaire pour convertir date Excel (numérique ou string)
    function parseExcelDate(value) {
        if (!value || value === "") return null;
        if (typeof value === 'number') {
            const date = new Date((value - 25569) * 86400 * 1000);
            if (!isNaN(date.getTime())) return date;
        }
        if (typeof value === 'string') {
            let trimmed = value.trim();
            let d = new Date(trimmed);
            if (!isNaN(d.getTime())) return d;
            let parts = trimmed.split(/[\/\-]/);
            if (parts.length === 3) {
                let day = parseInt(parts[0],10);
                let month = parseInt(parts[1],10)-1;
                let year = parseInt(parts[2],10);
                if (!isNaN(year) && !isNaN(month) && !isNaN(day)) {
                    let parsed = new Date(year, month, day);
                    if (!isNaN(parsed.getTime())) return parsed;
                }
            }
        }
        return null;
    }

    // calcul différence jours entre deux Date JS (floor)
    function daysDiff(date1, date2) {
        if (!date1 || !date2) return null;
        const diffTime = Math.abs(date2 - date1);
        return Math.floor(diffTime / (1000 * 60 * 60 * 24));
    }

    // extraire un nombre depuis "Temps unitaire" (chiffres, point/virgule)
    function parseTempsUnitaire(value) {
        if (value === undefined || value === null || value === "") return null;
        // si c'est déjà un nombre
        if (typeof value === 'number') return isNaN(value) ? null : value;
        // si c'est une chaîne
        const str = String(value).trim().replace(',', '.');
        const num = parseFloat(str);
        return isNaN(num) ? null : num;
    }

    // Traitement principal
    function processExcelData(workbook) {
        const sheetName = "DATA";
        const sheet = workbook.Sheets[sheetName];
        if (!sheet) {
            document.getElementById("uploadFeedback").innerHTML = `<div class="error-msg"><i class="fas fa-exclamation-triangle"></i> Erreur : La feuille "${sheetName}" est introuvable dans le fichier. Vérifiez le nom exacte (majuscule).</div>`;
            document.getElementById("chartsArea").style.display = "none";
            document.getElementById("kpiContainer").innerHTML = `<div class="kpi-card"><div class="kpi-title">⚠️ Erreur</div><div class="kpi-value">Feuille DATA absente</div></div>`;
            return;
        }
        const data = XLSX.utils.sheet_to_json(sheet, { defval: "" });
        if (!data || data.length === 0) {
            document.getElementById("uploadFeedback").innerHTML = `<div class="error-msg"><i class="fas fa-database"></i> La feuille DATA ne contient aucune donnée.</div>`;
            return;
        }

        // Colonnes indispensables (soft)
        const requiredCols = ["Domaine", "Statut", "Agent", "Date_A_TRAITER"];
        const firstRow = data[0];
        const missing = requiredCols.filter(col => !(col in firstRow));
        if (missing.length) {
            document.getElementById("uploadFeedback").innerHTML = `<div class="error-msg"><i class="fas fa-table"></i> Colonnes manquantes : ${missing.join(", ")}. Vérifiez l'en-tête Excel.</div>`;
            return;
        }

        // On construit les enregistrements enrichis avec les dates et TEMPS UNITAIRE
        const records = data.map(row => {
            const rawDateA = row["Date_A_TRAITER"];
            const rawDateFin = row["Date_FIN"];
            const rawDateRetrait = row["Date_de_Retraitement"];
            const dateA = parseExcelDate(rawDateA);
            const dateFin = parseExcelDate(rawDateFin);
            const dateRetrait = parseExcelDate(rawDateRetrait);
            let processingDays = null;
            if (dateA && dateFin && dateFin >= dateA) {
                processingDays = daysDiff(dateA, dateFin);
            }
            let retreatmentDelay = null;
            if (dateA && dateRetrait && dateRetrait >= dateA) {
                retreatmentDelay = daysDiff(dateA, dateRetrait);
            }
            // Lecture de la colonne "Temps unitaire" (nom exact)
            let rawTemps = row["Temps unitaire"];
            let tempsUnitaire = parseTempsUnitaire(rawTemps);
            
            return {
                ...row,
                _dateA: dateA,
                _dateFin: dateFin,
                _dateRetrait: dateRetrait,
                _processingDays: processingDays,
                _retreatmentDelay: retreatmentDelay,
                _tempsUnitaire: tempsUnitaire,   // valeur numérique ou null
                domaine: row["Domaine"] ? String(row["Domaine"]).trim() : "Non défini",
                sousDomaine: row["SousDomaine"] ? String(row["SousDomaine"]).trim() : "Indéfini",
                statut: row["Statut"] ? String(row["Statut"]).trim() : "Inconnu",
                agent: row["Agent"] ? String(row["Agent"]).trim() : "Non renseigné",
                status2: row["Status_2"] ? String(row["Status_2"]).trim() : ""
            };
        });

        // Calculs KPI globaux
        const totalRecords = records.length;
        const uniqueAgents = new Set(records.map(r => r.agent).filter(a => a !== "Non renseigné")).size;
        const finishedTasks = records.filter(r => r._dateFin !== null);
        const avgProcessingDays = finishedTasks.reduce((acc, r) => acc + (r._processingDays || 0), 0) / (finishedTasks.length || 1);
        
        const closedStatusKeywords = ["terminé", "fermé", "clos", "closed", "résolu", "finalisé", "traité"];
        const pendingTasks = records.filter(r => {
            const statutLow = r.statut.toLowerCase();
            const isClosed = closedStatusKeywords.some(keyword => statutLow.includes(keyword));
            const hasNoFinish = r._dateFin === null;
            return (!isClosed || hasNoFinish) && hasNoFinish;
        });
        const pendingCount = pendingTasks.length;
        
        const retreatmentCases = records.filter(r => r._dateRetrait !== null).length;
        
        const today = new Date();
        today.setHours(0,0,0,0);
        const overdueTasks = pendingTasks.filter(r => {
            if (!r._dateA) return false;
            const diffDays = daysDiff(r._dateA, today);
            return diffDays !== null && diffDays > 7;
        }).length;
        
        const retreatmentDelays = records.filter(r => r._retreatmentDelay !== null).map(r => r._retreatmentDelay);
        const avgRetreatDelay = retreatmentDelays.length ? (retreatmentDelays.reduce((a,b)=>a+b,0)/retreatmentDelays.length).toFixed(1) : 0;
        
        const validDates = records.map(r => r._dateA).filter(d => d !== null);
        let minDate = validDates.length ? new Date(Math.min(...validDates)) : null;
        let maxDate = validDates.length ? new Date(Math.max(...validDates)) : null;
        const dateRangeStr = (minDate && maxDate) ? `${minDate.toLocaleDateString('fr-FR')} → ${maxDate.toLocaleDateString('fr-FR')}` : "N/A";
        
        const completionRate = totalRecords ? ((finishedTasks.length / totalRecords) * 100).toFixed(1) : 0;
        
        // Affichage KPI
        const kpiHtml = `
            <div class="kpi-card"><div class="kpi-title"><i class="fas fa-database"></i> Total dossiers</div><div class="kpi-value">${totalRecords}</div><div class="kpi-sub">intégrés</div></div>
            <div class="kpi-card"><div class="kpi-title"><i class="fas fa-users"></i> Collaborateurs uniques</div><div class="kpi-value">${uniqueAgents}</div><div class="kpi-sub">agents actifs</div></div>
            <div class="kpi-card"><div class="kpi-title"><i class="fas fa-hourglass-half"></i> Délai moyen (traitement)</div><div class="kpi-value">${avgProcessingDays > 0 ? avgProcessingDays.toFixed(1) : '—'}</div><div class="kpi-sub">jours (Date_A_TRAITER → Date_FIN)</div></div>
            <div class="kpi-card"><div class="kpi-title"><i class="fas fa-clock"></i> En attente / Pendings</div><div class="kpi-value">${pendingCount}</div><div class="kpi-sub">dossiers non finalisés</div></div>
            <div class="kpi-card"><div class="kpi-title"><i class="fas fa-exclamation-triangle"></i> Dossiers en retard</div><div class="kpi-value">${overdueTasks}</div><div class="kpi-sub">>7j sans finalisation</div></div>
            <div class="kpi-card"><div class="kpi-title"><i class="fas fa-rotate-left"></i> Retraitements</div><div class="kpi-value">${retreatmentCases}</div><div class="kpi-sub">délai moyen: ${avgRetreatDelay}j</div></div>
            <div class="kpi-card"><div class="kpi-title"><i class="fas fa-chart-simple"></i> Taux complétion</div><div class="kpi-value">${completionRate}%</div><div class="kpi-sub">${finishedTasks.length} traités</div></div>
            <div class="kpi-card"><div class="kpi-title"><i class="fas fa-calendar-alt"></i> Période extraction</div><div class="kpi-value" style="font-size:1.2rem;">${dateRangeStr}</div><div class="kpi-sub">Date_A_TRAITER</div></div>
        `;
        document.getElementById("kpiContainer").innerHTML = kpiHtml;
        document.getElementById("chartsArea").style.display = "block";
        
        // --- Préparation des données pour graphiques ---
        // 1. Statut distribution
        const statutCount = new Map();
        records.forEach(r => { let s = r.statut; statutCount.set(s, (statutCount.get(s)||0)+1); });
        const statusLabels = Array.from(statutCount.keys()).slice(0, 8);
        const statusValues = statusLabels.map(l => statutCount.get(l));
        
        // 2. Domaine counts (top domaines)
        const domaineCount = new Map();
        records.forEach(r => { let d = r.domaine; domaineCount.set(d, (domaineCount.get(d)||0)+1); });
        const sortedDomains = Array.from(domaineCount.entries()).sort((a,b)=>b[1]-a[1]).slice(0,8);
        const domainLabels = sortedDomains.map(d=>d[0]);
        const domainValues = sortedDomains.map(d=>d[1]);
        
        // 3. Timeline mensuelle (Date_A_TRAITER)
        const monthlyMap = new Map();
        records.forEach(r => {
            if (r._dateA) {
                const year = r._dateA.getFullYear();
                const month = r._dateA.getMonth()+1;
                const key = `${year}-${month.toString().padStart(2,'0')}`;
                monthlyMap.set(key, (monthlyMap.get(key)||0)+1);
            }
        });
        const sortedMonths = Array.from(monthlyMap.keys()).sort();
        const timelineValues = sortedMonths.map(m => monthlyMap.get(m));
        
        // 4. Top agents
        const agentCount = new Map();
        records.forEach(r => { let ag = r.agent; if(ag !== "Non renseigné") agentCount.set(ag, (agentCount.get(ag)||0)+1); });
        const sortedAgents = Array.from(agentCount.entries()).sort((a,b)=>b[1]-a[1]).slice(0,8);
        const agentLabels = sortedAgents.map(a=>a[0]);
        const agentValues = sortedAgents.map(a=>a[1]);
        
        // 5. NOUVEAU : Temps unitaire moyen par Domaine (remplace l'ancien délai traitement)
        const tempsUnitaireParDomaine = new Map(); // domaine -> { somme, count }
        records.forEach(r => {
            if (r._tempsUnitaire !== null && r.domaine) {
                let dom = r.domaine;
                if (!tempsUnitaireParDomaine.has(dom)) tempsUnitaireParDomaine.set(dom, { total: 0, cnt: 0 });
                let curr = tempsUnitaireParDomaine.get(dom);
                curr.total += r._tempsUnitaire;
                curr.cnt += 1;
                tempsUnitaireParDomaine.set(dom, curr);
            }
        });
        // Transformer en tableau avec moyenne, trier par moyenne décroissante (ou conserver le topX)
        let unitTimeEntries = Array.from(tempsUnitaireParDomaine.entries())
            .map(([dom, {total, cnt}]) => ([dom, total / cnt]))
            .filter(([, avg]) => !isNaN(avg) && isFinite(avg))
            .sort((a,b) => b[1] - a[1]) // ordre descendant
            .slice(0, 8); // max 8 domaines pour lisibilité
        const unitTimeDomains = unitTimeEntries.map(d => d[0]);
        const unitTimeAvg = unitTimeEntries.map(d => d[1].toFixed(1)); // une décimale
        
        // 6. SousDomaine Top 7
        const subCount = new Map();
        records.forEach(r => { let sub = r.sousDomaine; subCount.set(sub, (subCount.get(sub)||0)+1); });
        const sortedSub = Array.from(subCount.entries()).sort((a,b)=>b[1]-a[1]).slice(0,7);
        const subLabels = sortedSub.map(s=>s[0]);
        const subValues = sortedSub.map(s=>s[1]);
        
        // Destruction des anciens graphiques
        Object.keys(charts).forEach(key => {
            if (charts[key] && typeof charts[key].destroy === 'function') {
                charts[key].destroy();
            }
        });
        
        // Création des graphiques
        const ctxStatus = document.getElementById('statusPieChart').getContext('2d');
        charts.status = new Chart(ctxStatus, {
            type: 'pie',
            data: { labels: statusLabels, datasets: [{ data: statusValues, backgroundColor: ['#2c6e9e','#4c9fcf','#ff9f4a','#57a6a1','#a3c9e6','#d9663b','#7f8c8d','#e8b86b'], borderWidth: 0 }] },
            options: { responsive: true, maintainAspectRatio: true, plugins: { legend: { position: 'right' } } }
        });
        
        const ctxDomain = document.getElementById('domainBarChart').getContext('2d');
        charts.domain = new Chart(ctxDomain, {
            type: 'bar', data: { labels: domainLabels, datasets: [{ label: 'Nombre de dossiers', data: domainValues, backgroundColor: '#2c6e9e', borderRadius: 8 }] },
            options: { responsive: true, maintainAspectRatio: true }
        });
        
        const ctxTimeline = document.getElementById('timelineChart').getContext('2d');
        charts.timeline = new Chart(ctxTimeline, {
            type: 'line', data: { labels: sortedMonths, datasets: [{ label: 'Soumissions', data: timelineValues, borderColor: '#ff7e33', backgroundColor: 'rgba(255,126,51,0.05)', tension: 0.3, fill: true, pointBackgroundColor: '#0066a1' }] },
            options: { responsive: true, maintainAspectRatio: true }
        });
        
        const ctxAgent = document.getElementById('agentBarChart').getContext('2d');
        charts.agent = new Chart(ctxAgent, {
            type: 'bar', data: { labels: agentLabels, datasets: [{ label: 'Dossiers traités', data: agentValues, backgroundColor: '#00a8b5', borderRadius: 8 }] },
            options: { responsive: true, maintainAspectRatio: true, indexAxis: 'y' }
        });
        
        // Graphique de la moyenne du temps unitaire par domaine (ex-domainDurationChart)
        const ctxUnitTime = document.getElementById('domainDurationChart').getContext('2d');
        charts.domainDuration = new Chart(ctxUnitTime, {
            type: 'bar', 
            data: { 
                labels: unitTimeDomains.length ? unitTimeDomains : ['Aucune donnée "Temps unitaire"'],
                datasets: [{ 
                    label: 'Moyenne du Temps unitaire', 
                    data: unitTimeDomains.length ? unitTimeAvg : [0], 
                    backgroundColor: '#498cba',
                    borderRadius: 8
                }] 
            },
            options: { 
                responsive: true, 
                maintainAspectRatio: true,
                plugins: {
                    tooltip: { callbacks: { label: (ctx) => `${ctx.raw} unité(s)` } },
                    legend: { position: 'top' }
                },
                scales: { y: { title: { display: true, text: 'Temps unitaire (moyenne)' } } }
            }
        });
        
        const ctxSub = document.getElementById('subdomainChart').getContext('2d');
        charts.subdomain = new Chart(ctxSub, {
            type: 'doughnut', data: { labels: subLabels, datasets: [{ data: subValues, backgroundColor: ['#386b7f','#64b5c6','#ffaa66','#b0c4de','#cd5c5c','#6a9c78','#ce93d8'] }] },
            options: { responsive: true, maintainAspectRatio: true, plugins: { legend: { position: 'right' } } }
        });
        
        // Message de succès avec mention du temps unitaire
        let hasTempsInfo = unitTimeEntries.length ? ` ${unitTimeEntries.length} domaines avec données "Temps unitaire".` : ' Aucune valeur numérique trouvée dans la colonne "Temps unitaire".';
        document.getElementById("uploadFeedback").innerHTML = `<div style="background:#e0f0e8; padding:8px 16px; border-radius:40px; margin-top:12px; color:#1f6e43;"><i class="fas fa-check-circle"></i> Fichier importé avec succès · ${totalRecords} enregistrements analysés (feuille DATA).${hasTempsInfo}</div>`;
    }
    
    // Gestionnaire upload fichier
    document.getElementById('fileInput').addEventListener('change', function(e) {
        const file = e.target.files[0];
        if (!file) return;
        const fileExt = file.name.split('.').pop().toLowerCase();
        if (!['xlsx', 'xls', 'csv'].includes(fileExt)) {
            document.getElementById("uploadFeedback").innerHTML = `<div class="error-msg"><i class="fas fa-file"></i> Format non supporté. Veuillez importer .xlsx ou .xls</div>`;
            return;
        }
        const reader = new FileReader();
        reader.onload = function(loadEvent) {
            const dataBinary = loadEvent.target.result;
            const workbook = XLSX.read(dataBinary, { type: 'array', cellDates: false, defval: "" });
            try {
                processExcelData(workbook);
            } catch (err) {
                console.error(err);
                document.getElementById("uploadFeedback").innerHTML = `<div class="error-msg"><i class="fas fa-bug"></i> Erreur lors du traitement : ${err.message}</div>`;
                document.getElementById("chartsArea").style.display = "none";
            }
        };
        reader.onerror = () => {
            document.getElementById("uploadFeedback").innerHTML = `<div class="error-msg"><i class="fas fa-times-circle"></i> Impossible de lire le fichier.</div>`;
        };
        reader.readAsArrayBuffer(file);
    });
    
    // initialisation par défaut
    document.getElementById("chartsArea").style.display = "none";
    const defaultKpis = `<div class="kpi-card"><div class="kpi-title"><i class="fas fa-cloud-upload-alt"></i> En attente d'import</div><div class="kpi-value">📂</div><div class="kpi-sub">Chargez un fichier Excel contenant une feuille DATA</div></div>
    <div class="kpi-card"><div class="kpi-title"><i class="fas fa-chart-line"></i> KPIs dynamiques</div><div class="kpi-value">---</div><div class="kpi-sub">Indicateurs après extraction</div></div>`;
    document.getElementById("kpiContainer").innerHTML = defaultKpis;
</script>
</body>
</html>
