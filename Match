' Bouton pour déplacer un dossier de NON CONFORME vers TRAITES (onglet 2)
' --------------------------------------------------------------
Private Sub CommandButton2_Click()
    On Error GoTo GestionErreur
    
    Dim FSO As Object
    Set FSO = CreateObject("Scripting.FileSystemObject")
    
    Dim dossierSource As String
    Dim dstPath As String
    Dim nomDossier As String
    Dim destinationFinale As String
    Dim statutFinal As String
    Dim srcPath As String
    Dim fileName As String
    
    ' Vérifier sélection
    If lstResultats.ListIndex = -1 Or lstResultats.Value = "DOSSIER VIDE" Then
        MsgBox "Sélectionnez un dossier", vbExclamation
        Exit Sub
    End If
    
    fileName = lstResultats.Value
    
    ' Sélection dossier source
    With Application.FileDialog(msoFileDialogFolderPicker)
        .Title = "Sélectionner le dossier à déplacer"
        If .Show <> -1 Then Exit Sub
        dossierSource = .SelectedItems(1)
    End With
    
    If Right(dossierSource, 1) = "\" Then
        dossierSource = Left(dossierSource, Len(dossierSource) - 1)
    End If
    
    ' Construction source : dossier NON CONFORME du fichier sélectionné
    ' Ici, on suppose que le dossier source est celui du fichier sélectionné
    If cboRacine.Value = "DIRCO" Then
        srcPath = basePath & "DIRCO\" & cboSousDossier.Value & "\FICHES CLIENTS\NON CONFORME\" & fileName
        ' Pour DIRCO, destination = ...\CM\FICHES CLIENTS\TRAITES\
        dstPath = basePath & "DIRCO\" & cboSousDossier.Value & "\FICHES CLIENTS\TRAITES"
    ElseIf cboRacine.Value = "ACM" Then
        srcPath = basePath & "ACM\NON CONFORME\" & cboSousDossier.Value & "\" & fileName
        dstPath = basePath & "ACM\TRAITES\" & cboSousDossier.Value
    ElseIf cboRacine.Value = "CONTRATHEQUE" Then
        srcPath = basePath & "CONTRATHEQUE\" & cboSousDossier.Value & "\NON CONFORME\" & fileName
        dstPath = basePath & "CONTRATHEQUE\" & cboSousDossier.Value & "\TRAITES"
    Else
        ' Autres domaines
        srcPath = basePath & cboRacine.Value & "\NON CONFORME\" & fileName
        dstPath = basePath & cboRacine.Value & "\TRAITES"
    End If
    
    ' Destination finale
    nomDossier = FSO.GetFolder(dossierSource).Name
    destinationFinale = dstPath & "\" & nomDossier
    
    ' Chemin historique (optionnel)
    Dim histoPath As String
    histoPath = "\\uf11pu01\ACCESSIBILITÉ_CONSEILLERS\ACCESSIBILITE\Historique" & "\" & fileName
    
    ' Vérifier si existe déjà
    If FSO.FolderExists(destinationFinale) Then
        MsgBox "Le dossier existe déjà à destination.", vbExclamation
        Exit Sub
    End If
    
    ' Déplacer : copier puis supprimer l'original
    FSO.CopyFolder dossierSource, destinationFinale, True
    FSO.DeleteFolder srcPath, True
    
    If FSO.FolderExists(destinationFinale) Then
        FSO.DeleteFolder dossierSource, True
        MsgBox "Dossier déplacé avec succès.", vbInformation
    Else
        MsgBox "Erreur lors de la copie.", vbCritical
    End If
    
    ' Journaliser
    LogAction "Déplacement", fileName, txtAgent, "de NON CONFORME à TRAITES"
    
    Exit Sub
    
GestionErreur:
    MsgBox "Erreur - " & Err.Number & " - " & Err.Description, vbCritical
End Sub

