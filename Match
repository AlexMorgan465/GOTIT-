' === BOUTON DEPLACER UN DOSSIER DEPUIS LE BUREAU ===
Private Sub CommandButton_DeplacerDossier_Click()
    Dim CheminDestination As String
    Dim DossierSource As String
    Dim NomDossier As String
    Dim Rep As VbMsgBoxResult
    
    ' Vérifie que la destination est sélectionnée
    CheminDestination = ConstruireChemin("To", 4)
    If CheminDestination = "" Then
        MsgBox "Sélectionne d'abord le dossier de destination avec les ComboBox de droite", vbExclamation
        Exit Sub
    End If
    
    If Not fso.FolderExists(CheminDestination) Then
        MsgBox "Dossier de destination introuvable", vbCritical
        Exit Sub
    End If
    
    ' Ouvre la fenêtre pour choisir un dossier sur le bureau
    With Application.FileDialog(msoFileDialogFolderPicker)
        .Title = "Sélectionne le dossier à déplacer"
        .InitialFileName = Environ("USERPROFILE") & "\Desktop\" ' Ouvre directement sur le bureau
        .AllowMultiSelect = False
        
        If .Show = -1 Then ' Si l'utilisateur a cliqué OK
            DossierSource = .SelectedItems(1)
        Else
            Exit Sub ' Annulé
        End If
    End With
    
    NomDossier = fso.GetFolder(DossierSource).Name
    
    Rep = MsgBox("Déplacer ce dossier ?" & vbCrLf & _
                 NomDossier & vbCrLf & _
                 "De : " & DossierSource & vbCrLf & _
                 "Vers : " & CheminDestination & "\" & NomDossier, vbYesNo + vbQuestion)
    
    If Rep = vbNo Then Exit Sub
    
    On Error GoTo ErreurMoveDossier
    
    ' Vérifie si un dossier du même nom existe déjà
    If fso.FolderExists(CheminDestination & "\" & NomDossier) Then
        Rep = MsgBox("Un dossier '" & NomDossier & "' existe déjà dans la destination." & vbCrLf & _
                     "Veux-tu l'écraser ?", vbYesNo + vbExclamation)
        If Rep = vbNo Then Exit Sub
        fso.DeleteFolder CheminDestination & "\" & NomDossier, True
    End If
    
    ' Déplace le dossier complet avec tout son contenu
    fso.MoveFolder DossierSource, CheminDestination & "\"
    
    MsgBox "Dossier déplacé avec succès !", vbInformation
    
    ' Rafraîchit la liste destination pour voir le nouveau dossier
    AfficherFichiers "To"
    Exit Sub
    
ErreurMoveDossier:
    MsgBox "Erreur pendant le déplacement du dossier : " & Err.Description & vbCrLf & _
           "Vérifie que le dossier n'est pas ouvert dans l'explorateur", vbCritical
End Sub
