' --------------------------------------------------------------
' Bouton pour passer de EN COURS à TRAITES / NON CONFORME (fichier)
' Ce bouton utilise un sélecteur de dossier pour copier un dossier
' (Attention : la logique semble mêler fichier et dossier ; à clarifier)
' --------------------------------------------------------------
Private Sub CommandButton1_Click()
    On Error GoTo GestionErreur
    
    Dim FSO As Object
    Set FSO = CreateObject("Scripting.FileSystemObject")
    
    Dim dossierSource As String
    Dim dstPath As String
    Dim nomDossier As String
    Dim destinationFinale As String
    Dim statutFinal As String
    Dim structType As StructureType
    Dim srcPath As String
    Dim fileName As String
    Dim ws As Worksheet
    Dim row As Long
    
    Set ws = ThisWorkbook.Sheets("SHEET_TRACE_NAME")
    row = GetTraceRow(ws, fileName)
    
    If lstFichiers.ListIndex = -1 Or lstFichiers.Value = "[DOSSIER VIDE]" Then
        MsgBox "Sélectionnez un fichier", vbExclamation
        Exit Sub
    End If
    
    fileName = lstFichiers.Value
    structType = GetDomainStructure(cmbDomaine.Value)
    
    ' Déterminer statut final
    If optTraites.Value = True Then
        statutFinal = "TRAITES"
    ElseIf optNonConforme.Value = True Then
        statutFinal = "NON CONFORME"
    Else
        MsgBox "Veuillez sélectionner TRAITES ou NON CONFORME."
        Exit Sub
    End If
    
    If statutFinal = "NON CONFORME" And txtCommentaire.Value = "" Then
        MsgBox "AJOUTE UN COMMENTAIRE"
        Exit Sub
    End If
    
    ' Sélection dossier source (le dossier à déplacer)
    With Application.FileDialog(msoFileDialogFolderPicker)
        .Title = "Sélectionner le dossier à déplacer"
        If .Show <> -1 Then Exit Sub
        dossierSource = .SelectedItems(1)
    End With
    
    If Right(dossierSource, 1) = "\" Then
        dossierSource = Left(dossierSource, Len(dossierSource) - 1)
    End If
    
    ' Construction du chemin source (dossier contenant le fichier ?)
    ' Ici, on suppose que le dossier à déplacer est celui du fichier sélectionné
    ' Cette partie est floue, mais on garde la logique existante en l'adaptant
    If cmbDomaine.Value = "DIRCO" Then
        srcPath = ROOT_PATH & "DIRCO\" & cmbSousCategorie.Value & "\" & _
                  cmbSousDomaine.Value & "\" & "EN COURS"
    Else
        Select Case cmbDomaine.Value
            Case "DIRCO", "ACM"
                srcPath = ROOT_PATH & cmbDomaine & "\" & _
                          "EN COURS" & "\" & cmbSousDomaine
            Case "CONTRATHEQUE"
                srcPath = ROOT_PATH & cmbDomaine & "\" & cmbSousDomaine.Value & "\" & "EN COURS"
            Case Else
                srcPath = ROOT_PATH & cmbDomaine & "\" & "EN COURS"
        End Select
    End If
    srcPath = srcPath & "\" & fileName
    
    ' Construction destination
    If cmbDomaine.Value = "DIRCO" Then
        dstPath = ROOT_PATH & "DIRCO\" & cmbSousCategorie.Value & "\" & _
                  cmbSousDomaine.Value & "\" & statutFinal
    Else
        Select Case cmbDomaine.Value
            Case "DIRCO", "ACM"
                dstPath = ROOT_PATH & cmbDomaine.Value & "\" & _
                          statutFinal & "\" & cmbSousDomaine.Value
            Case "CONTRATHEQUE"
                dstPath = ROOT_PATH & cmbDomaine.Value & "\" & _
                          cmbSousDomaine.Value & "\" & statutFinal
            Case Else
                dstPath = ROOT_PATH & cmbDomaine.Value & "\" & statutFinal
        End Select
    End If
    
    ' Chemin historique (copie de sauvegarde)
    Dim histoPath As String
    histoPath = "\\uf11pu01\ACCESSIBILITÉ_CONSEILLERS\ACCESSIBILITE\Historique" & "\" & fileName
    
    ' Journaliser avant déplacement
    LogAction "Déplacement", fileName, cmbDomaine.Value, cmbSousDomaine.Value, txtAgent, txtCommentaire.Value, _
              cmbStatutSource & " ? " & statutFinal
    
    ' Mettre à jour la feuille de traçabilité (pairing des lignes)
    Dim wsLog As Worksheet
    Dim wsTrace As Worksheet
    Dim lastRow As Long
    Dim i As Long
    Dim outputRow As Long
    Dim agentName As String
    Dim Comment As String
    Dim Domaine As String
    Dim SousDomaine As String
    Dim startDate As Variant
    Dim endDate As Variant
    Dim details As String
    Dim status As String
    Dim parts() As String
    
    Set wsLog = ThisWorkbook.Sheets("LOG_ACTIONS")
    Set wsTrace = ThisWorkbook.Sheets("SHEET_TRACE_NAME")
    
    ' Clear old trace (except headers)
    wsTrace.Rows("2:" & wsTrace.Rows.Count).ClearContents
    
    lastRow = wsLog.Cells(wsLog.Rows.Count, "A").End(xlUp).row
    outputRow = 2
    i = 2
    
    Do While i <= lastRow
        fileName = wsLog.Cells(i, 3).Value
        Domaine = wsLog.Cells(i, 4).Value
        SousDomaine = wsLog.Cells(i, 7).Value
        agentName = wsLog.Cells(i, 5).Value
        startDate = wsLog.Cells(i, 1).Value
        Comment = wsLog.Cells(i + 1, 8).Value
        
        If i + 1 <= lastRow Then
            endDate = wsLog.Cells(i + 1, 1).Value
            details = wsLog.Cells(i + 1, 6).Value
            If InStr(details, "?") > 0 Then
                parts = Split(details, "?")
                status = Trim(parts(UBound(parts)))
            Else
                status = details
            End If
            
            wsTrace.Cells(outputRow, 1).Value = fileName
            wsTrace.Cells(outputRow, 2).Value = Domaine
            wsTrace.Cells(outputRow, 3).Value = SousDomaine
            wsTrace.Cells(outputRow, 4).Value = status
            wsTrace.Cells(outputRow, 5).Value = startDate
            wsTrace.Cells(outputRow, 6).Value = endDate
            wsTrace.Cells(outputRow, 7).Value = agentName
            wsTrace.Cells(outputRow, 8).Value = wsTrace.Cells(outputRow, 6).Value - wsTrace.Cells(outputRow, 5).Value
            wsTrace.Cells(outputRow, 9).Value = Comment
            
            outputRow = outputRow + 1
        End If
        
        i = i + 2
    Loop
    
    MsgBox "Trace générée avec succès!", vbInformation
    
    ' Recharger
    LoadFichiers
    txtCommentaire.Value = ""
    
    ' Déplacer le dossier
    nomDossier = FSO.GetFolder(dossierSource).Name
    destinationFinale = dstPath & "\" & nomDossier
    
    If FSO.FolderExists(destinationFinale) Then
        MsgBox "Le dossier existe déjà à destination.", vbExclamation
        Exit Sub
    End If
    
    ' Copier puis supprimer l'original
    Name srcPath As histoPath   ' déplace le fichier dans historique
    FSO.CopyFolder dossierSource, destinationFinale, True
    
    If FSO.FolderExists(destinationFinale) Then
        FSO.DeleteFolder dossierSource, True
        MsgBox "Dossier déplacé vers " & statutFinal, vbInformation
    Else
        MsgBox "Erreur lors de la copie.", vbCritical
    End If
    
    Exit Sub
    
GestionErreur:
    MsgBox "Erreur : " & Err.Number & " - " & Err.Description, vbCritical
End Sub

