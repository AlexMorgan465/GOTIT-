Private Sub cmb_Supprimmer_Click()

    If vue.ListIndex < 0 Then
        MsgBox "Veuillez sélectionner une ligne à supprimer.", vbExclamation
        Exit Sub
    End If

    Dim ws As Worksheet
    Set ws = ThisWorkbook.Worksheets("temp")

    Dim selectedValue As String
    Dim i As Long, lastRow As Long

    selectedValue = vue.List(vue.ListIndex, 2)

    lastRow = ws.Cells(ws.Rows.Count, 1).End(xlUp).Row

    For i = 2 To lastRow
        If ws.Cells(i, 3).Value = selectedValue Then
            ws.Rows(i).Delete
            Exit For
        End If
    Next i

    MsgBox "Ligne supprimée avec succès.", vbInformation

    lastRow = ws.Cells(ws.Rows.Count, 1).End(xlUp).Row

    If lastRow >= 2 Then
        vue.List = ws.Range("A2:I" & lastRow).Value
    Else
        vue.Clear
    End If
    
    Dim wx As Worksheet
    
    Set wx = ThisWorkbook.Worksheets("extraction")
    ligne = lastRow + 1
    With wx
        .Cells(ligne, 1).Value = agent.Value
        .Cells(ligne, 2).Value = Format(Date, "dd/mm/yyyy")
        .Cells(ligne, 3).Value = cmbActivite.Value
        .Cells(ligne, 4).Value = cmbProduit.Value
        .Cells(ligne, 5).Value = txtDossier.Value
        .Cells(ligne, 6).Value = cmbDecision.Value
        .Cells(ligne, 7).Value = cmbDocument.Value
        .Cells(ligne, 8).Value = comment.Value
        .Cells(ligne, 9).Value = Now
        .Cells(ligne, 10).Value = "Supprimé"
    End With

End Sub

