End Sub

' --------------------------------------------------------------
' Chargement des fichiers dans lstFichiers selon le chemin construit
' --------------------------------------------------------------
Private Sub LoadFichiers()
    Dim path As String
    
    lstFichiers.Clear
    
    If cmbDomaine = "" Or cmbStatutSource = "" Then Exit Sub
    
    ' --- Pour DIRCO, chemin inclut la sous-catégorie ---
    If cmbDomaine.Value = "DIRCO" Then
        If cmbSousCategorie.Value = "" Or cmbSousDomaine.Value = "" Then Exit Sub
        path = ROOT_PATH & "DIRCO\" & cmbSousCategorie.Value & "\" & _
               cmbSousDomaine.Value & "\" & cmbStatutSource.Value
    Else
        ' --- Autres domaines ---
        Dim structType As StructureType
        structType = GetDomainStructure(cmbDomaine.Value)
        
        Select Case structType
            Case SIMPLE
                path = ROOT_PATH & cmbDomaine.Value & "\" & cmbStatutSource.Value
                
            Case Complex
                If cmbSousDomaine.Value = "" Then Exit Sub
                path = ROOT_PATH & cmbDomaine.Value & "\" & _
                       cmbSousDomaine.Value & "\" & cmbStatutSource.Value
                
            Case THREE_LEVEL ' ACM
                If cmbStatutSource.Value = "A TRAITER" Then
                    path = ROOT_PATH & cmbDomaine.Value & "\A TRAITER\" & cmbSousDomaine.Value
                ElseIf cmbStatutSource.Value = "EN COURS" Then
                    path = ROOT_PATH & cmbDomaine.Value & "\EN COURS\" & cmbSousDomaine.Value
                End If
        End Select
    End If
    
    ' Charger les fichiers
    If FolderExists(path) Then
        LoadFilesToList lstFichiers, path
    Else
        lstFichiers.AddItem "[DOSSIER VIDE]"
    End If
End Sub

' --------------------------------------------------------------
' Bouton Déplacer (A TRAITER -> EN COURS) pour un fichier
' --------------------------------------------------------------
Private Sub cmdDeplacer_Click()
    Dim srcPath As String, dstPath As String
    Dim fileName As String
    Dim ws As Worksheet
    Dim row As Long
    
    ' Validation
    If lstFichiers.ListIndex = -1 Or lstFichiers.Value = "[DOSSIER VIDE]" Then
        MsgBox "Sélectionnez un fichier", vbExclamation
        Exit Sub
    End If
    
    If txtAgent = "" Then
        MsgBox "Agent requis", vbCritical
        Exit Sub
    End If
    
    fileName = lstFichiers.Value
    
    ' Construire les chemins
    ' Source : le fichier est dans le dossier correspondant au statut source
    ' Destination : le dossier EN COURS correspondant
    
    If cmbDomaine.Value = "DIRCO" Then
        ' Source : dans A TRAITER (statut source)
        srcPath = ROOT_PATH & "DIRCO\" & cmbSousCategorie.Value & "\" & _
                  cmbSousDomaine.Value & "\" & "A TRAITER"   ' on suppose toujours A TRAITER en source
        ' Si le statut source peut être autre, utilisez cmbStatutSource.Value
        ' Mais dans votre logique, c'est "A TRAITER" -> "EN COURS"
        dstPath = ROOT_PATH & "DIRCO\" & cmbSousCategorie.Value & "\" & _
                  cmbSousDomaine.Value & "\" & "EN COURS"
    Else
        ' Source
        Dim structType As StructureType
        structType = GetDomainStructure(cmbDomaine.Value)
        
        Select Case structType
            Case SIMPLE
                srcPath = ROOT_PATH & cmbDomaine & "\" & "A TRAITER"
            Case Complex
                srcPath = ROOT_PATH & cmbDomaine & "\" & cmbSousDomaine & "\" & "A TRAITER"
            Case THREE_LEVEL
                ' Ici on suppose que le statut source est "A TRAITER" ou "EN COURS"
                ' On utilise cmbStatutSource pour déterminer le bon dossier
                If cmbStatutSource.Value = "A TRAITER" Then
                    srcPath = ROOT_PATH & cmbDomaine & "\A TRAITER\" & cmbSousDomaine
                Else
                    srcPath = ROOT_PATH & cmbDomaine & "\" & "A TRAITER"
                End If
        End Select
        
        ' Destination
        Select Case structType
            Case SIMPLE
                dstPath = ROOT_PATH & cmbDomaine & "\" & "EN COURS"
            Case Complex
                dstPath = ROOT_PATH & cmbDomaine & "\" & cmbSousDomaine & "\" & "EN COURS"
            Case THREE_LEVEL
                If cmbStatutSource.Value = "A TRAITER" Then
                    dstPath = ROOT_PATH & cmbDomaine & "\EN COURS\" & cmbSousDomaine
                Else
                    dstPath = ROOT_PATH & cmbDomaine & "\" & "EN COURS"
                End If
        End Select
    End If
    
    srcPath = srcPath & "\" & fileName
    dstPath = dstPath & "\" & fileName
    
    ' Créer dossier destination si besoin
    CreateFolderIfNotExists dstPath
    
    ' Déplacer
    Name srcPath As dstPath
    
    ' Mettre à jour traçabilité
    Set ws = ThisWorkbook.Sheets("SHEET_TRACE_NAME")
    row = GetTraceRow(ws, fileName)
    
    ' Journaliser
    LogAction "Déplacement", fileName, cmbDomaine.Value, cmbSousDomaine.Value, txtAgent, txtCommentaire.Value, _
              cmbStatutSource & " ? " & cmbStatutDestination
    
    ' Recharger
    LoadFichiers
    txtCommentaire.Value = ""
    
    MsgBox "Fichier déplacé avec succès !", vbInformation
End Sub

