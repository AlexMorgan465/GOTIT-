Private Sub cmb_Ajouter_Click()
    ' --- Condition ajoutée : vérifier qu'aucune ligne en attente n'existe ---
    Dim wsTemp As Worksheet
    Set wsTemp = GetTempSheet()
    
    Dim lastRow As Long, i As Long
    lastRow = wsTemp.Cells(wsTemp.Rows.Count, 1).End(xlUp).Row
    
    For i = 2 To lastRow
        ' Si la ligne a une heure de début (colonne C) mais pas d'heure de fin (colonne D)
        If wsTemp.Cells(i, 3).Value <> "" And wsTemp.Cells(i, 4).Value = "" Then
            MsgBox "Veuillez compléter la ligne précédente (en attente) avant d'ajouter un nouveau dossier.", vbExclamation
            Exit Sub
        End If
    Next i
    ' --- fin de l'ajout ---
    
