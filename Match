Type DomainStructure
    HasStatutFolders As Boolean          ' Présence de "A TRAITER", "EN COURS", etc.
    LevelCount As Integer                ' 0 = statuts directement sous racine, 1 = un sous-niveau, etc.
    SubLevels As Collection              ' Noms des sous-dossiers du premier niveau (ex: "Particuliers")
    PathToStatut As String               ' Chemin de base avant le dossier statut (ex: "\\...\ACM")
End Type

Function AnalyzeDomainStructure(domainPath As String) As DomainStructure
    Dim fso As Object, baseFolder As Object, subFolder As Object
    Dim stats() As Variant
    Dim i As Integer, found As Integer
    Dim struct As DomainStructure
    
    Set fso = CreateObject("Scripting.FileSystemObject")
    If Not fso.FolderExists(domainPath) Then
        struct.HasStatutFolders = False
        AnalyzeDomainStructure = struct
        Exit Function
    End If
    
    Set baseFolder = fso.GetFolder(domainPath)
    struct.PathToStatut = domainPath
    struct.SubLevels = New Collection
    
    ' Liste des noms de statuts possibles (selon votre logique métier)
    stats = Array("A TRAITER", "EN COURS", "TRAITES", "NON CONFORME")
    
    ' Vérifier si les dossiers de statut sont directement sous domainPath
    For Each subFolder In baseFolder.SubFolders
        For i = LBound(stats) To UBound(stats)
            If StrComp(subFolder.Name, stats(i), vbTextCompare) = 0 Then
                found = found + 1
                Exit For
            End If
        Next
    Next
    
    If found > 0 Then
        ' Structure directe : domainPath\A TRAITER, etc.
        struct.HasStatutFolders = True
        struct.LevelCount = 0
    Else
        ' Sinon, on cherche un niveau intermédiaire (ex: "ACM\Particuliers\A TRAITER")
        For Each subFolder In baseFolder.SubFolders
            ' On regarde si ce sous-dossier contient lui-même des dossiers de statut
            If HasStatutFolders(subFolder.Path, stats) Then
                struct.HasStatutFolders = True
                struct.LevelCount = 1
                struct.SubLevels.Add subFolder.Name
                struct.PathToStatut = subFolder.Path
            End If
        Next
        
        ' Si toujours rien, on pourrait chercher un 2ème niveau (ex: "DIRCO\FICHES CLIENTS\A TRAITER")
        If Not struct.HasStatutFolders Then
            For Each subFolder In baseFolder.SubFolders
                Dim subSub As Object
                For Each subSub In subFolder.SubFolders
                    If HasStatutFolders(subSub.Path, stats) Then
                        struct.HasStatutFolders = True
                        struct.LevelCount = 2
                        struct.SubLevels.Add subFolder.Name
                        struct.SubLevels.Add subSub.Name
                        struct.PathToStatut = subSub.Path
                        Exit For
                    End If
                Next
                If struct.HasStatutFolders Then Exit For
            Next
        End If
    End If
    
    AnalyzeDomainStructure = struct
End Function

' Fonction utilitaire
Function HasStatutFolders(folderPath As String, statuts As Variant) As Boolean
    Dim fso As Object, fol As Object, subFol As Object
    Dim i As Integer
    Set fso = CreateObject("Scripting.FileSystemObject")
    If Not fso.FolderExists(folderPath) Then Exit Function
    Set fol = fso.GetFolder(folderPath)
    For Each subFol In fol.SubFolders
        For i = LBound(statuts) To UBound(statuts)
            If StrComp(subFol.Name, statuts(i), vbTextCompare) = 0 Then
                HasStatutFolders = True
                Exit Function
            End If
        Next
    Next
End Function
