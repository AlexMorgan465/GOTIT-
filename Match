Voici une version simplifiée où :

Rechercher affiche les dossiers présents dans NON CONFORME.

L'utilisateur sélectionne un dossier dans lstResultats.

En cliquant sur CommandButton2, le dossier est déplacé de NON CONFORME vers TRAITES.

Plus besoin de FileDialog.


Bouton Rechercher

Private Sub cmdRechercher_Click()

    LoadFichiers_NC

End Sub


---

Chargement des dossiers de NON CONFORME

Private Sub LoadFichiers_NC()

    Dim path As String
    Dim FSO As Object
    Dim dossier As Object
    Dim sousDossier As Object

    lstResultats.Clear

    If cboRacine.Value = "" Or cboSousDossier.Value = "" Then Exit Sub

    Select Case cboRacine.Value

        Case "CONTRATHEQUE"
            path = ROOT_PATH & "\" & cboRacine.Value & "\" & _
                   cboSousDossier.Value & "\NON CONFORME"

        Case "DIRCO", "ACM", "CMO"
            path = ROOT_PATH & "\" & cboRacine.Value & _
                   "\NON CONFORME\" & cboSousDossier.Value

        Case Else
            path = ROOT_PATH & "\" & cboRacine.Value & "\NON CONFORME"

    End Select

    Set FSO = CreateObject("Scripting.FileSystemObject")

    If FSO.FolderExists(path) Then

        Set dossier = FSO.GetFolder(path)

        For Each sousDossier In dossier.SubFolders

            lstResultats.AddItem sousDossier.Name
            lstResultats.List(lstResultats.ListCount - 1, 1) = sousDossier.Path

        Next sousDossier

    Else

        lstResultats.AddItem "DOSSIER VIDE"

    End If

End Sub


---

Double-clic sur un dossier (optionnel)

Private Sub lstResultats_DblClick(ByVal Cancel As MSForms.ReturnBoolean)

    If lstResultats.ListIndex <> -1 Then
        Shell "explorer.exe """ & _
              lstResultats.List(lstResultats.ListIndex, 1) & """", vbNormalFocus
    End If

End Sub


