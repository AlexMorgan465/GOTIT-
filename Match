Sub SearchData_REF()
    Dim ws As Worksheet
    Set ws = GetTempSheet()
    
    vue.Clear
    If ws.Cells(2, 1).Value = "" Then
        MsgBox "Aucune donnée trouvée.", vbInformation
        Exit Sub
    End If
    
    Dim lastRow As Long
    lastRow = ws.Cells(ws.Rows.Count, 1).End(xlUp).Row
    
    Dim searchContract As String
    searchContract = InputBox("Entrez la référence dossier :", "Recherche")
    
    If searchContract = "" Then
        Call RefreshListView
        Exit Sub
    End If
    
    Dim colRef As Long
    If cmbTraitement.Value = "SOLVA" Then colRef = 6 Else colRef = 7
    
    Dim results As Collection
    Set results = New Collection
    Dim i As Long
    For i = 2 To lastRow
        If InStr(1, ws.Cells(i, colRef).Value, searchContract, vbTextCompare) > 0 Then
            results.Add i
        End If
    Next i
    
    If results.Count = 0 Then
        MsgBox "Aucun dossier trouvé.", vbInformation
        Exit Sub
    End If
    
    Dim nbCol As Integer
    If cmbTraitement.Value = "SOLVA" Then nbCol = 6 Else nbCol = 9
    Dim arr()
    ReDim arr(1 To results.Count, 1 To nbCol)
    Dim j As Integer, r As Integer
    r = 1
    For Each i In results
        For j = 1 To nbCol
            arr(r, j) = ws.Cells(i, j).Value
        Next j
        r = r + 1
    Next i
    
    vue.List = arr
End Sub

