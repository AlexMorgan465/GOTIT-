Sub SearchData_activ()

    Dim ws As Worksheet
    Set ws = ThisWorkbook.Worksheets("temp")

    vue.Clear
    vue.ColumnWidths = "80;80;80;80;80;80;80;80"
    vue.ColumnHeads = True
    
    If ws.Cells(2, 1).Value = "" Then
        MsgBox "Aucune donnée trouvée.", vbInformation
        Exit Sub
    End If

    Dim lastRow As Long
    lastRow = ws.Cells(ws.Rows.Count, 1).End(xlUp).Row
    
    vue.ColumnCount = 9
    
    Dim searchContract As String
    searchContract = InputBox("Entrez la référence dossier :", "Recherche")

    Dim i As Long
    
    If searchContract = "" Then
        vue.List = ws.Range("A2:I" & lastRow).Value
        Set rng1 = ws.Range("A1:I" & ws.Range("A" & ws.Rows.Count).End(xlUp).Row)
        With Me.vue
            .BorderStyle = 1
            .BorderColor = &H80000012
            
            .Clear
        '.ColumnHeads = True
            .ColumnCount = rng1.Columns.Count
            MyArray1 = rng1
            .List = MyArray1
            .ColumnWidths = "80;80;80;80;80;80;80;80"
        End With
        Exit Sub
    End If
    
    Dim results As Collection
    Set results = New Collection
    
    For i = 2 To lastRow
        If InStr(1, ws.Cells(i, 3).Value, searchContract, vbTextCompare) > 0 Then
            results.Add i
        End If
    Next i
    
    If results.Count = 0 Then
        MsgBox "Aucun dossier trouvé.", vbInformation
        Exit Sub
    End If
    
    Dim arr()
    ReDim arr(1 To results.Count, 1 To 9)
    
    For i = 1 To results.Count
        arr(i, 1) = ws.Cells(results(i), 1).Value
        arr(i, 2) = ws.Cells(results(i), 2).Value
        arr(i, 3) = ws.Cells(results(i), 3).Value
        arr(i, 4) = ws.Cells(results(i), 4).Value
        arr(i, 5) = ws.Cells(results(i), 5).Value
        arr(i, 6) = ws.Cells(results(i), 6).Value
        arr(i, 7) = ws.Cells(results(i), 7).Value
        arr(i, 8) = ws.Cells(results(i), 8).Value
        arr(i, 9) = ws.Cells(results(i), 9).Value
    Next i

    vue.List = arr

End Sub
