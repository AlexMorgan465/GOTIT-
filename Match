Private Function GetSubFolders(path As String) As Collection
    ' Retourne une collection des noms des sous-dossiers de path
    Dim col As New Collection
    Dim fso As Object
    Dim folder As Object
    Dim subfolder As Object
    
    Set fso = CreateObject("Scripting.FileSystemObject")
    If fso.FolderExists(path) Then
        Set folder = fso.GetFolder(path)
        For Each subfolder In folder.subFolders
            col.Add subfolder.Name
        Next
    End If
    Set GetSubFolders = col
End Function

Private Function GetNonStatutFolders(path As String) As Collection
    ' Retourne les sous-dossiers qui ne sont pas des statuts (A TRAITER, EN COURS, TRAITES, NON CONFORME)
    Dim col As New Collection
    Dim fso As Object
    Dim folder As Object
    Dim subfolder As Object
    
    Set fso = CreateObject("Scripting.FileSystemObject")
    If fso.FolderExists(path) Then
        Set folder = fso.GetFolder(path)
        For Each subfolder In folder.subFolders
            If UCase(subfolder.Name) <> "A TRAITER" And _
               UCase(subfolder.Name) <> "EN COURS" And _
               UCase(subfolder.Name) <> "TRAITES" And _
               UCase(subfolder.Name) <> "NON CONFORME" Then
                col.Add subfolder.Name
            End If
        Next
    End If
    Set GetNonStatutFolders = col
End Function

Private Function GetDomainStructure(domain As String) As StructureType
    ' Détermine le type de structure pour le domaine
    If domain = "ACM" Then
        GetDomainStructure = THREE_LEVEL
    ElseIf domain = "DIRCO" Or domain = "CONTRATHEQUE" Then
        GetDomainStructure = Complex
    Else
        GetDomainStructure = SIMPLE
    End If
End Function

Private Function FolderExists(path As String) As Boolean
    Dim fso As Object
    Set fso = CreateObject("Scripting.FileSystemObject")
    FolderExists = fso.FolderExists(path)
End Function

Private Sub LoadFilesToList(lst As MSForms.ListBox, path As String)
    Dim fso As Object
    Dim folder As Object
    Dim file As Object
    
    lst.Clear
    Set fso = CreateObject("Scripting.FileSystemObject")
    If fso.FolderExists(path) Then
        Set folder = fso.GetFolder(path)
        For Each file In folder.Files
            lst.AddItem file.Name
        Next
    End If
End Sub

Private Sub CreateFolderIfNotExists(path As String)
    Dim fso As Object
    Set fso = CreateObject("Scripting.FileSystemObject")
    If Not fso.FolderExists(path) Then
        fso.CreateFolder path
    End If
End Sub

Private Function GetTraceRow(ws As Worksheet, fileName As String) As Long
    ' Placeholder : retourne la ligne où se trouve le nom de fichier dans la feuille de traçabilité
    Dim rng As Range
    Set rng = ws.Columns(1).Find(What:=fileName, LookAt:=xlWhole)
    If Not rng Is Nothing Then
        GetTraceRow = rng.Row
    Else
        GetTraceRow = ws.Cells(ws.Rows.Count, 1).End(xlUp).row + 1
    End If
End Function

Private Sub LogAction(action As String, fileName As String, domaine As String, sousDomaine As String, agent As String, commentaire As String, details As String)
    ' Ajoute une ligne dans la feuille LOG_ACTIONS
    Dim ws As Worksheet
    Dim lastRow As Long
    
    Set ws = ThisWorkbook.Sheets("LOG_ACTIONS")
    lastRow = ws.Cells(ws.Rows.Count, 1).End(xlUp).row + 1
    
    ws.Cells(lastRow, 1).Value = Now
    ws.Cells(lastRow, 2).Value = action
    ws.Cells(lastRow, 3).Value = fileName
    ws.Cells(lastRow, 4).Value = domaine
    ws.Cells(lastRow, 5).Value = agent
    ws.Cells(lastRow, 6).Value = details
    ws.Cells(lastRow, 7).Value = sousDomaine
    ws.Cells(lastRow, 8).Value = commentaire
End Sub

