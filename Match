<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<title>Dashboard KPI - Crédit Mutuel</title>

<!-- Librairies -->
<script src="https://cdn.jsdelivr.net/npm/xlsx/dist/xlsx.full.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
    body {
        font-family: "Segoe UI", sans-serif;
        margin: 0;
        background: #f4f6f9;
    }

    header {
        background: #c4002f;
        color: white;
        padding: 15px;
        text-align: center;
        font-size: 22px;
        font-weight: bold;
    }

    .container {
        padding: 20px;
    }

    .upload-box {
        background: white;
        padding: 20px;
        border-radius: 10px;
        margin-bottom: 20px;
        text-align: center;
        box-shadow: 0 2px 6px rgba(0,0,0,0.1);
    }

    .kpi {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
        margin-bottom: 20px;
    }

    .card {
        background: white;
        padding: 20px;
        border-radius: 10px;
        text-align: center;
        box-shadow: 0 2px 6px rgba(0,0,0,0.1);
    }

    .card h2 {
        margin: 0;
        color: #c4002f;
    }

    .charts {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 20px;
    }

    canvas {
        background: white;
        padding: 10px;
        border-radius: 10px;
    }
</style>
</head>

<body>

<header>Dashboard KPI - Crédit Mutuel</header>

<div class="container">

    <div class="upload-box">
        <input type="file" id="fileInput" />
    </div>

    <div class="kpi">
        <div class="card">
            <h2 id="total">0</h2>
            <p>Total dossiers</p>
        </div>

        <div class="card">
            <h2 id="traite">0</h2>
            <p>Traités</p>
        </div>

        <div class="card">
            <h2 id="attente">0</h2>
            <p>En attente</p>
        </div>
    </div>

    <div class="charts">
        <canvas id="statusChart"></canvas>
        <canvas id="agentChart"></canvas>
    </div>

</div>

<script>
let statusChart, agentChart;

document.getElementById('fileInput').addEventListener('change', handleFile);

function handleFile(e) {
    const file = e.target.files[0];
    const reader = new FileReader();

    reader.onload = function(event) {
        const data = new Uint8Array(event.target.result);
        const workbook = XLSX.read(data, { type: 'array' });

        const sheet = workbook.Sheets["DATA"];
        const json = XLSX.utils.sheet_to_json(sheet);

        processData(json);
    };

    reader.readAsArrayBuffer(file);
}

function processData(data) {
    let total = data.length;
    let traite = 0;
    let attente = 0;

    let statusCount = {};
    let agentCount = {};

    data.forEach(row => {
        let statut = row["Statut"] || "Inconnu";
        let agent = row["Agent"] || "N/A";

        // KPI logique
        if (statut.toLowerCase().includes("traité")) {
            traite++;
        } else {
            attente++;
        }

        // Comptage statut
        statusCount[statut] = (statusCount[statut] || 0) + 1;

        // Comptage agent
        agentCount[agent] = (agentCount[agent] || 0) + 1;
    });

    // Mise à jour KPI
    document.getElementById("total").innerText = total;
    document.getElementById("traite").innerText = traite;
    document.getElementById("attente").innerText = attente;

    drawCharts(statusCount, agentCount);
}

function drawCharts(statusData, agentData) {

    if (statusChart) statusChart.destroy();
    if (agentChart) agentChart.destroy();

    // Chart Statut
    statusChart = new Chart(document.getElementById("statusChart"), {
        type: 'pie',
        data: {
            labels: Object.keys(statusData),
            datasets: [{
                data: Object.values(statusData),
            }]
        }
    });

    // Chart Agent
    agentChart = new Chart(document.getElementById("agentChart"), {
        type: 'bar',
        data: {
            labels: Object.keys(agentData),
            datasets: [{
                label: "Dossiers par agent",
                data: Object.values(agentData),
            }]
        }
    });
}
</script>

</body>
</html>
