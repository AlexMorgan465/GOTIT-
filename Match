Sub ClearForm()
    typecredit.Value = ""
    typeproduit.Value = ""
    refdos.Value = ""
    typesignature.Value = ""

    decision.Value = ""
End Sub
Sub UpdateData()
    Dim ws As Worksheet
    Set ws = ThisWorkbook.Worksheets("OCAOCR")
    
    With ws
        .Cells(currentRow, 3).Value = Now
        .Cells(currentRow, 7).Value = typesignature.Value
        .Cells(currentRow, 8).Value = decision.Value
        .Cells(currentRow, 9).Value = comment.Value
        .Cells(currentRow, 10).Value = .Cells(currentRow, 3).Value - .Cells(currentRow, 2).Value
    End With
End Sub
