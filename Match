Private Sub cboRacine_Change()
    Dim cheminBase As String
    Dim dossier As Object, sousDossier As Object
    
    cboSousDossier.Clear
    
    Select Case cboRacine.Value
        Case "ACM"
            ' Pour ACM, les sous-dossiers sont les types (ex: "Société", "Particulier")
            cheminBase = basePath & "ACM\" & STATUT_NON_CONFORME & "\"
            If FSO.FolderExists(cheminBase) Then
                Set dossier = FSO.GetFolder(cheminBase)
                For Each sousDossier In dossier.subFolders
                    cboSousDossier.AddItem sousDossier.Name
                Next sousDossier
            End If
            If cboSousDossier.ListCount = 0 Then cboSousDossier.AddItem "(Aucun sous-dossier)"
            
        Case "DIRCO"
            ' Pour DIRCO, les sous-dossiers sont les clients (ex: "AXA", "BNP")
            cheminBase = basePath & "DIRCO\"
            If FSO.FolderExists(cheminBase) Then
                Set dossier = FSO.GetFolder(cheminBase)
                For Each sousDossier In dossier.subFolders
                    ' On exclut les dossiers de statut
                    If sousDossier.Name <> STATUT_A_TRAITER And _
                       sousDossier.Name <> STATUT_EN_COURS And _
                       sousDossier.Name <> STATUT_TRAITES And _
                       sousDossier.Name <> STATUT_NON_CONFORME Then
                        cboSousDossier.AddItem sousDossier.Name
                    End If
                Next sousDossier
            End If
            If cboSousDossier.ListCount = 0 Then cboSousDossier.AddItem "(Aucun client)"
            
        Case "CONTRATHEQUE"
            cboSousDossier.AddItem "CONDITIONS GENERALES"
            cboSousDossier.AddItem "Conventions"
            cboSousDossier.AddItem "Document d’Information Tarifaire"
            cboSousDossier.AddItem "Granties"
            cboSousDossier.AddItem "Politique de Protection"
            
        Case Else
            cboSousDossier.AddItem "(Aucun)"
    End Select
End Sub

Private Sub cmdRechercher_Click()
    Dim cheminRecherche As String
    Dim dossierRacine As Object
    
    If cboRacine.Value = "" Then
        MsgBox "Veuillez sélectionner une racine.", vbExclamation
        Exit Sub
    End If
    
    lstResultats.Clear
    
    ' Construire le chemin de base pour la recherche
    Select Case cboRacine.Value
        Case "ACM"
            cheminRecherche = basePath & "ACM\" & STATUT_NON_CONFORME
            If cboSousDossier.Value <> "" And cboSousDossier.Value <> "(Aucun sous-dossier)" Then
                cheminRecherche = cheminRecherche & "\" & cboSousDossier.Value
            End If
        Case "DIRCO"
            cheminRecherche = basePath & "DIRCO"
            If cboSousDossier.Value <> "" And cboSousDossier.Value <> "(Aucun client)" Then
                cheminRecherche = cheminRecherche & "\" & cboSousDossier.Value & "\FICHES CLIENTS"
            End If
        Case "CONTRATHEQUE"
            cheminRecherche = basePath & "CONTRATHEQUE"
            If cboSousDossier.Value <> "" And cboSousDossier.Value <> "(Aucun)" Then
                cheminRecherche = cheminRecherche & "\" & cboSousDossier.Value
            End If
        Case Else
            cheminRecherche = basePath & cboRacine.Value
    End Select
    
    If Not FSO.FolderExists(cheminRecherche) Then
        MsgBox "Le dossier de recherche n'existe pas : " & cheminRecherche, vbExclamation
        Exit Sub
    End If
    
    Set dossierRacine = FSO.GetFolder(cheminRecherche)
    Call SearchNonConformeFolders(dossierRacine)
    
    If lstResultats.ListCount = 0 Then
        MsgBox "Aucun dossier 'NON CONFORME' trouvé dans cette arborescence.", vbInformation
    End If
End Sub

Private Sub SearchNonConformeFolders(ByVal dossier As Object)
    Dim subFolder As Object, innerFolder As Object
    
    ' Parcourir les sous-dossiers
    For Each subFolder In dossier.subFolders
        ' Si on trouve un dossier "NON CONFORME", on liste ses sous-dossiers (les dossiers clients ou types)
        If subFolder.Name = STATUT_NON_CONFORME Then
            For Each innerFolder In subFolder.subFolders
                lstResultats.AddItem innerFolder.Name
                lstResultats.List(lstResultats.ListCount - 1, 1) = innerFolder.Path
            Next innerFolder
        Else
            ' Sinon, continuer la recherche récursive
            SearchNonConformeFolders subFolder
        End If
    Next subFolder
End Sub

Private Sub lstResultats_DblClick(ByVal Cancel As MSForms.ReturnBoolean)
    If lstResultats.ListIndex <> -1 Then
        Shell "explorer.exe """ & lstResultats.List(lstResultats.ListIndex, 1) & """", vbNormalFocus
    End If
End Sub

' ============================================================================
' DÉPLACEMENT D'UN DOSSIER NON CONFORME → TRAITES
' ============================================================================

Private Sub CommandButton2_Click()
    Dim srcPath As String, dstPath As String
    Dim folderName As String
    Dim cheminDestBase As String
    
    If lstResultats.ListIndex = -1 Then
        MsgBox "Sélectionnez un dossier dans la liste.", vbExclamation
        Exit Sub
    End If
    
    srcPath = lstResultats.List(lstResultats.ListIndex, 1)
    If Not FSO.FolderExists(srcPath) Then
        MsgBox "Le dossier source n'existe plus.", vbExclamation
        Exit Sub
    End If
    
    folderName = lstResultats.Value
    
    ' Construire le chemin de destination selon la racine
    Select Case cboRacine.Value
        Case "ACM"
            ' ACM\TRAITES\<sous-dossier>\
            cheminDestBase = basePath & "ACM\" & STATUT_TRAITES
            If cboSousDossier.Value <> "" And cboSousDossier.Value <> "(Aucun sous-dossier)" Then
                cheminDestBase = cheminDestBase & "\" & cboSousDossier.Value
            End If
        Case "DIRCO"
            ' DIRCO\<client>\FICHES CLIENTS\TRAITES
            If cboSousDossier.Value = "" Or cboSousDossier.Value = "(Aucun client)" Then
                MsgBox "Veuillez sélectionner un client dans la liste.", vbExclamation
                Exit Sub
            End If
            cheminDestBase = basePath & "DIRCO\" & cboSousDossier.Value & "\FICHES CLIENTS\" & STATUT_TRAITES
        Case "CONTRATHEQUE"
            cheminDestBase = basePath & "CONTRATHEQUE"
            If cboSousDossier.Value <> "" And cboSousDossier.Value <> "(Aucun)" Then
                cheminDestBase = cheminDestBase & "\" & cboSousDossier.Value
            End If
            cheminDestBase = cheminDestBase & "\" & STATUT_TRAITES
        Case Else
            cheminDestBase = basePath & cboRacine.Value & "\" & STATUT_TRAITES
    End Select
    
    CreateFolderIfNotExists cheminDestBase
    dstPath = cheminDestBase & "\" & folderName
    
    ' Copier puis supprimer l'original (car déplacement de dossier)
    On Error GoTo ErrorHandler
    FSO.CopyFolder srcPath, dstPath, True
    FSO.DeleteFolder srcPath, True
    
    ' Log
    LogAction "Déplacement NON CONFORME → TRAITES", folderName, cboRacine.Value, _
              cboSousDossier.Value, txtAgent.Value, "", _
              "Dossier entier déplacé de NON CONFORME vers TRAITES"
    
    ' Rafraîchir la liste
    cmdRechercher_Click
    MsgBox "Dossier déplacé vers TRAITES avec succès.", vbInformation
    Exit Sub
    
ErrorHandler:
    MsgBox "Erreur lors du déplacement : " & Err.Description, vbCritical
End Sub

