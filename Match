Option Explicit
Dim fso As Object
Const CHEMIN_RACINE As String = "C:\Users\HAMDANMO\Desktop\Accessibilité"

Private Sub UserForm_Initialize()
    Set fso = CreateObject("Scripting.FileSystemObject")
    
    If Not fso.FolderExists(CHEMIN_RACINE) Then
        MsgBox "Chemin introuvable : " & CHEMIN_RACINE, vbCritical
        Exit Sub
    End If
    
    ChargerNiveau1
End Sub

' Niveau 1 : ACM, Bouygues telecom, CIC CIB..., CONTRATHEQUE, DIRCO
Private Sub ChargerNiveau1()
    Dim DossierRacine As Object, SousDossier As Object
    Set DossierRacine = fso.GetFolder(CHEMIN_RACINE)
    
    Me.ComboBox1.Clear
    For Each SousDossier In DossierRacine.SubFolders
        Me.ComboBox1.AddItem SousDossier.Name
    Next SousDossier
    
    If Me.ComboBox1.ListCount > 0 Then Me.ComboBox1.ListIndex = 0
End Sub

' Niveau 2 : A TRAITER, EN COURS, CONDITIONS GENERALES, CIC, etc
Private Sub ComboBox1_Change()
    RemplirComboBox 2
End Sub

' Niveau 3 : Assurances-Biens, A TRAITER, FICHES CLIENTS, etc
Private Sub ComboBox2_Change()
    RemplirComboBox 3
End Sub

' Niveau 4 : Nouveau dossier, A TRAITER, etc
Private Sub ComboBox3_Change()
    RemplirComboBox 4
End Sub

Private Sub ComboBox4_Change()
    Me.ListBox1.Clear
End Sub

' Fonction générique pour remplir les ComboBox en cascade
Private Sub RemplirComboBox(Niveau As Integer)
    Dim Chemin As String, Dossier As Object, SousDossier As Object
    Dim Cbx As MSForms.ComboBox
    
    ' Vide les ComboBox suivants
    Select Case Niveau
        Case 2: Me.ComboBox2.Clear: Me.ComboBox3.Clear: Me.ComboBox4.Clear: Set Cbx = Me.ComboBox2
        Case 3: Me.ComboBox3.Clear: Me.ComboBox4.Clear: Set Cbx = Me.ComboBox3
        Case 4: Me.ComboBox4.Clear: Set Cbx = Me.ComboBox4
    End Select
    Me.ListBox1.Clear
    
    ' Construit le chemin selon les ComboBox remplies
    Chemin = CHEMIN_RACINE
    If Me.ComboBox1.Value <> "" Then Chemin = Chemin & "\" & Me.ComboBox1.Value
    If Niveau > 2 And Me.ComboBox2.Value <> "" Then Chemin = Chemin & "\" & Me.ComboBox2.Value
    If Niveau > 3 And Me.ComboBox3.Value <> "" Then Chemin = Chemin & "\" & Me.ComboBox3.Value
    
    If Chemin = CHEMIN_RACINE Then Exit Sub
    
    If fso.FolderExists(Chemin) Then
        Set Dossier = fso.GetFolder(Chemin)
        For Each SousDossier In Dossier.SubFolders
            Cbx.AddItem SousDossier.Name
        Next SousDossier
        If Cbx.ListCount > 0 Then Cbx.ListIndex = 0
    End If
End Sub

' Bouton : affiche les fichiers du dernier dossier sélectionné
Private Sub CommandButton1_Click()
    Dim CheminComplet As String
    Dim Dossier As Object, Fichier As Object
    
    Me.ListBox1.Clear
    
    ' Construit le chemin avec tous les niveaux remplis
    CheminComplet = CHEMIN_RACINE
    If Me.ComboBox1.Value = "" Then GoTo ErreurSelection
    CheminComplet = CheminComplet & "\" & Me.ComboBox1.Value
    
    If Me.ComboBox2.Value <> "" Then CheminComplet = CheminComplet & "\" & Me.ComboBox2.Value
    If Me.ComboBox3.Value <> "" Then CheminComplet = CheminComplet & "\" & Me.ComboBox3.Value
    If Me.ComboBox4.Value <> "" Then CheminComplet = CheminComplet & "\" & Me.ComboBox4.Value
    
    If Not fso.FolderExists(CheminComplet) Then
        MsgBox "Dossier introuvable", vbCritical
        Exit Sub
    End If
    
    Set Dossier = fso.GetFolder(CheminComplet)
    
    ' Si le dossier a des sous-dossiers, on prévient
    If Dossier.SubFolders.Count > 0 And Dossier.Files.Count = 0 Then
        Me.ListBox1.AddItem ">>> Ce dossier contient des sous-dossiers, pas de fichiers directs"
        Me.ListBox1.AddItem ">>> Sélectionne un niveau plus bas"
        Exit Sub
    End If
    
    If Dossier.Files.Count = 0 Then
        Me.ListBox1.AddItem "Aucun fichier dans : " & Dossier.Name
    Else
        Me.ListBox1.AddItem "=== Fichiers dans " & Dossier.Path & " ==="
        For Each Fichier In Dossier.Files
            Me.ListBox1.AddItem Fichier.Name
        Next Fichier
    End If
    Exit Sub
    
ErreurSelection:
    MsgBox "Sélectionne au moins le niveau 1", vbExclamation
End Sub

Private Sub UserForm_Terminate()
    Set fso = Nothing
End Sub
