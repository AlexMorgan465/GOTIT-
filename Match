' ============================================================================

Private Sub CommandButton3_Click()
    RefreshTraceSheet
    MsgBox "Trace générée avec succès.", vbInformation
End Sub

Private Sub RefreshTraceSheet()
    Dim wsLog As Worksheet, wsTrace As Worksheet
    Dim lastRow As Long, i As Long
    Dim dict As Object   ' Dictionnaire pour regrouper par fichier + sous-domaine
    Dim key As String
    Dim startDate As Variant, endDate As Variant, agent As String, comment As String
    Dim details As String, statusFinal As String
    
    Set wsLog = ThisWorkbook.Sheets("LOG_ACTIONS")
    Set wsTrace = ThisWorkbook.Sheets("SHEET_TRACE_NAME")
    
    ' Nettoyer anciennes données (garder en-têtes)
    wsTrace.Rows("2:" & wsTrace.Rows.Count).ClearContents
    
    ' Dictionnaire : clé = "Fichier|SousDomaine" pour regrouper début et fin
    Set dict = CreateObject("Scripting.Dictionary")
    
    lastRow = wsLog.Cells(wsLog.Rows.Count, "A").End(xlUp).Row
    If lastRow < 2 Then Exit Sub
    
    ' Parcourir chaque ligne de log (chaque ligne = une action)
    For i = 2 To lastRow
        Dim action As String, fichier As String, domaine As String, sousDomaine As String
        Dim agentLog As String, commentLog As String, detailsLog As String, dateLog As Date
        
        dateLog = wsLog.Cells(i, 1).Value
        action = wsLog.Cells(i, 2).Value
        fichier = wsLog.Cells(i, 3).Value
        domaine = wsLog.Cells(i, 4).Value
        agentLog = wsLog.Cells(i, 5).Value
        detailsLog = wsLog.Cells(i, 6).Value
        sousDomaine = wsLog.Cells(i, 7).Value
        commentLog = wsLog.Cells(i, 8).Value
        
        ' Clé unique par fichier + sousDomaine (un même fichier peut passer plusieurs fois ? On prend la dernière occurrence)
        key = fichier & "|" & sousDomaine
        
        If InStr(action, "A TRAITER → EN COURS") > 0 Then
            ' C'est le début du traitement
            If Not dict.exists(key) Then
                dict.Add key, CreateObject("Scripting.Dictionary")
            End If
            dict(key)("start") = dateLog
            dict(key)("agent") = agentLog
            dict(key)("comment") = commentLog
            dict(key)("domaine") = domaine
            dict(key)("sousDomaine") = sousDomaine
            dict(key)("fichier") = fichier
        ElseIf InStr(action, "EN COURS →") > 0 Then
            ' Fin du traitement
            If dict.exists(key) Then
                dict(key)("end") = dateLog
                ' Extraire le statut final depuis detailsLog (ex: "De EN COURS vers TRAITES")
                If InStr(detailsLog, "vers " & STATUT_TRAITES) > 0 Then
                    dict(key)("status") = STATUT_TRAITES
                ElseIf InStr(detailsLog, "vers " & STATUT_NON_CONFORME) > 0 Then
                    dict(key)("status") = STATUT_NON_CONFORME
                Else
                    dict(key)("status") = "Inconnu"
                End If
                ' Mettre à jour le commentaire si un nouveau est fourni (NON CONFORME)
                If commentLog <> "" Then dict(key)("comment") = commentLog
            Else
                ' Cas où on n'a pas l'action de début (anomalie) – on peut ignorer ou logger
            End If
        End If
    Next i
    
    ' Remplir la feuille de trace
    Dim outputRow As Long
    outputRow = 2
    Dim vKey As Variant
    For Each vKey In dict.Keys
        Dim item As Object
        Set item = dict(vKey)
        If item.exists("start") And item.exists("end") Then
            wsTrace.Cells(outputRow, 1).Value = item("fichier")
            wsTrace.Cells(outputRow, 2).Value = item("domaine")
            wsTrace.Cells(outputRow, 3).Value = item("sousDomaine")
            wsTrace.Cells(outputRow, 4).Value = item("status")
            wsTrace.Cells(outputRow, 5).Value = item("start")
            wsTrace.Cells(outputRow, 6).Value = item("end")
            wsTrace.Cells(outputRow, 7).Value = item("agent")
            If IsDate(item("start")) And IsDate(item("end")) Then
                wsTrace.Cells(outputRow, 8).Value = item("end") - item("start")
            Else
                wsTrace.Cells(outputRow, 8).Value = ""
            End If
            wsTrace.Cells(outputRow, 9).Value = item("comment")
            outputRow = outputRow + 1
        End If
    Next vKey
    
    wsTrace.Columns("A:I").AutoFit
End Sub

' ============================================================================
' LOGGING (Écriture dans LOG_ACTIONS)
' ============================================================================

Private Sub LogAction(action As String, fileName As String, domaine As String, _
                      sousDomaine As String, agent As String, comment As String, details As String)
    Dim wsLog As Worksheet
    Dim nextRow As Long
    
    Set wsLog = ThisWorkbook.Sheets("LOG_ACTIONS")
    nextRow = wsLog.Cells(wsLog.Rows.Count, "A").End(xlUp).Row + 1
    
    With wsLog
        .Cells(nextRow, 1).Value = Now
        .Cells(nextRow, 2).Value = action
        .Cells(nextRow, 3).Value = fileName
        .Cells(nextRow, 4).Value = domaine
        .Cells(nextRow, 5).Value = agent
        .Cells(nextRow, 6).Value = details
        .Cells(nextRow, 7).Value = sousDomaine
        .Cells(nextRow, 8).Value = comment
    End With
End Sub

