Sub CopierOcaocrDepuisTousCofidis()
    Dim WbDest As Workbook
    Dim WsDest As Worksheet
    Dim WbSource As Workbook
    Dim WsSource As Worksheet
    Dim CheminDossier As String
    Dim Fichier As String
    Dim PremiereCopie As Boolean
    
    Application.ScreenUpdating = False
    Application.DisplayAlerts = False
    Application.Calculation = xlCalculationManual
    
    Set WbDest = ThisWorkbook
    Set WsDest = WbDest.Sheets("ocaocr")
    
    ' Dossier à scanner : C:\Users\TonNom\Desktop\vba\
    CheminDossier = Environ("USERPROFILE") & "\Desktop\vba\"
    
    ' On vide la feuille destination une seule fois
    WsDest.Cells.Clear
    PremiereCopie = True
    
    Fichier = Dir(CheminDossier & "cofidis.xlsm")
    
    Do While Fichier <> ""
        Set WbSource = Workbooks.Open(CheminDossier & Fichier)
        
        On Error Resume Next
        Set WsSource = WbSource.Sheets("ocaocr")
        On Error GoTo 0
        
        If Not WsSource Is Nothing Then
            If PremiereCopie Then
                ' Premier fichier : on copie tout avec la même méthode
                WsSource.Cells.Copy Destination:=WsDest.Range("A1")
                PremiereCopie = False
            Else
                ' Fichiers suivants : on colle à la suite pour ne pas écraser
                Dim DerniereLigne As Long
                DerniereLigne = WsDest.Cells(WsDest.Rows.Count, 1).End(xlUp).Row + 1
                WsSource.Cells.Copy Destination:=WsDest.Range("A" & DerniereLigne)
            End If
        End If
        
        WbSource.Close SaveChanges:=False
        Set WsSource = Nothing
        Set WbSource = Nothing
        
        Fichier = Dir ' Passe au fichier suivant
    Loop
    
    Application.Calculation = xlCalculationAutomatic
    Application.DisplayAlerts = True
    Application.ScreenUpdating = True
    
    MsgBox "Copie terminée depuis tous les cofidis.xlsm du dossier !", vbInformation
End Sub
