            srcPath = ROOT_PATH & "\" & cmbDomaine.Value & "\" & STATUT_EN_COURS & "\" & fileName
        Case Complex
            srcPath = ROOT_PATH & "\" & cmbDomaine.Value & "\" & cmbSousDomaine.Value & "\" & STATUT_EN_COURS & "\" & fileName
        Case THREE_LEVEL
            srcPath = ROOT_PATH & "\" & cmbDomaine.Value & "\" & STATUT_EN_COURS & "\" & cmbSousDomaine.Value & "\" & fileName
        Case DIRCO_SPECIAL
            srcPath = ROOT_PATH & "\" & cmbDomaine.Value & "\" & cmbSousDomaine.Value & "\FICHES CLIENTS\" & STATUT_EN_COURS & "\" & fileName
