Sub OCAOCR_Procedure()
    Dim wsSource As Worksheet, wsDest As Worksheet
    Dim lastRow As Long, lastCol As Long
    Dim formatCol As Long
    Dim i As Long, destRow As Long
    Dim WbDest As Workbook
    Dim fso As Object
    Dim folder As Object
    Dim subfolder As Object
    Dim fichier As Object
    
    DossierChemin = "\\uf11pu01\COFIDIS_TC\A-PRODUCTION\1-PRODUCTION\CC DFRA\2-Nouveau répertoire"
    
    Set fso = CreateObject("Scripting.FileSystemObject")
    Set folder = fso.GetFolder(DossierChemin)
  
    Set wsDest = ThisWorkbook.Worksheets("OCAOCR")

    wsDest.Cells.Clear

For Each subfolder In folder.SubFolders

    For Each fichier In subfolder.Files
    If LCase(fso.GetExtensionName(fichier.Name)) Like "tmp" Then GoTo NEXTFICHIER
     If Left(fichier.Name, 2) = "~$" Then GoTo NEXTFICHIER
    Set WbDest = Workbooks.Open("\\uf11pu01\COFIDIS_TC\A-PRODUCTION\1-PRODUCTION\CC DFRA\2-Nouveau répertoire\" & subfolder.Name & "\Cofidis.xlsm")
    Set wsSource = WbDest.Worksheets("OCAOCR")

    lastCol = wsSource.Cells(1, wsSource.Columns.Count).End(xlToLeft).Column
    lastRow = wsSource.Cells(wsSource.Rows.Count, 1).End(xlUp).Row
    
        formatCol = 0
    For i = 1 To lastCol
        If LCase(wsSource.Cells(1, i).Value) = "i" Then
            formatCol = i
            Exit For
        End If
    Next i

    If formatCol = 0 Then
        MsgBox "Column 'format fichier' not found", vbCritical
        Exit Sub
    End If
If wsDest.Cells(1, 1).Value = "" Then
    wsSource.Rows(1).Copy wsDest.Rows(1)
    destRow = 2
End If

    ' Copy matching rows
    For i = 2 To lastRow
        If InStr(1, LCase(wsSource.Cells(i, formatCol).Value)) > 0 Then
            wsSource.Rows(i).Copy wsDest.Rows(destRow)
            destRow = destRow + 1
        End If
    Next i
        WbDest.Close
NEXTFICHIER:
    Next fichier
Next subfolder
End Sub
