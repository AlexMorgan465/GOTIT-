' ------------------------------------------------------------------
' Load selected row from ListView into form controls
' ------------------------------------------------------------------
Private Sub vue_Click()
    If vue.ListIndex >= 0 Then LoadSelectedData
End Sub

Sub LoadSelectedData()
    Dim ws As Worksheet
    Set ws = GetTempSheet()
    
    If vue.ListIndex < 0 Then Exit Sub
    
    ' Identify the reference value to locate the row in the sheet
    Dim refValue As String
    Dim refCol As Long
    If cmbTraitement.Value = "SOLVA" Then
        refCol = 6
        refValue = vue.List(vue.ListIndex, 5)   ' column 6 (F) is 0-based? Actually List is 0-based: column index 5 = 6th column
        ' Correction: List array is 0-based, so column 5 (index) = 6th column
        refValue = vue.List(vue.ListIndex, 5)
    Else
        refCol = 7
        refValue = vue.List(vue.ListIndex, 6)   ' column 7 (G)
    End If
    
    Dim lastRow As Long, i As Long
    lastRow = ws.Cells(ws.Rows.Count, 1).End(xlUp).Row
    
    For i = 2 To lastRow
        If ws.Cells(i, refCol).Value = refValue Then
            currentRow = i
            Exit For
        End If
    Next i
    
    If currentRow = 0 Then Exit Sub
    
    With ws
        If cmbTraitement.Value = "SOLVA" Then
            Solvabilité.Value = .Cells(currentRow, 5).Value
            txtDossier.Value = .Cells(currentRow, 6).Value
            cmbDecisionSolva.Value = .Cells(currentRow, 5).Value   ' assuming decision stored in col5
            comment.Value = .Cells(currentRow, 7).Value
        Else
            cmbCredit.Value = .Cells(currentRow, 5).Value
            cmbProduits.Value = .Cells(currentRow, 6).Value
            txtDossier.Value = .Cells(currentRow, 7).Value
            cmbSignature.Value = .Cells(currentRow, 8).Value
            cmbDecision.Value = .Cells(currentRow, 9).Value
            comment.Value = .Cells(currentRow, 10).Value
        End If
    End With
    
    isEditing = True
End Sub
