Sub UserForm_Initialize()

    Me.StartUpPosition = 0
    Me.Left = Application.Left + (Application.Width - Me.Width) / 2
    Me.Top = Application.Top + (Application.Height - Me.Height) / 2
    ' Initialiser les statuts
    typecredit.Clear
    typecredit.AddItem "AUG"
    typecredit.AddItem "OUV"
        
    typeproduit.AddItem "AUG ACC"
    typeproduit.AddItem "OUV ACC"
    typeproduit.AddItem "AUG PART"
    typeproduit.AddItem "OUV PSM"
    typeproduit.AddItem "OUV PSM/PSM"
    typeproduit.AddItem "OUV PSM d'AUG"
    
    typesignature.Clear
    typesignature.AddItem "SE"
    typesignature.AddItem "Papier"
    
    decision.Clear
    decision.AddItem "OCA"
    decision.AddItem "OCR"
    decision.AddItem "OCI"
    decision.AddItem "CPP"
    
    decision.AddItem "TDT"
    
    agent.Value = Environ("USERNAME")
End Sub

Sub valider_Click()

Dim ws As Worksheet
Dim ligne As Long
Dim refValue As String
Dim lastRow As Long
Dim i As Long

Set ws = ThisWorkbook.Worksheets("OCAOCR")

' Valeur tapée dans la textbox refdos
refValue = refdos.Value

' Vérifier si refvide
If Trim(refValue) = "" Then
    MsgBox "Veuillez saisir une référence dossier.", vbExclamation
    Exit Sub
End If

' Dernière ligne remplie
lastRow = ws.Cells(ws.Rows.Count, 1).End(xlUp).Row

' Vérification de doublon dans colonne 6
For i = 2 To lastRow
    If ws.Cells(i, 6).Value = refValue And ws.Cells(i, 4).Value = typecredit Then
        MsgBox "? La référence dossier '" & refValue & "' existe déjà !", vbCritical, "Doublon détecté"
        Exit Sub
    End If
Next i

' Si aucun doublon alors ajouter la ligne
ligne = lastRow + 1

With ws
    .Cells(ligne, 1).Value = agent.Value
    .Cells(ligne, 2).Value = Now
    .Cells(ligne, 4).Value = typecredit.Value
    .Cells(ligne, 5).Value = typeproduit.Value
    .Cells(ligne, 6).Value = refdos.Value
End With

' Réinitialisation des champs
typecredit.Value = ""
typeproduit.Value = ""
refdos.Value = ""
typesignature.Value = ""
decision.Value = ""
comment.Value = ""

MsgBox "Dossier ajouté avec succès !", vbInformation

End Sub

Private Sub vue_Click()
    If vue.ListIndex >= 0 Then LoadSelectedData
End Sub
Sub LoadSelectedData()
    If vue.ListIndex < 0 Then Exit Sub
    
    Dim ws As Worksheet
    Set ws = ThisWorkbook.Worksheets("OCAOCR")
    
    Dim valueContrat As String
    valueContrat = vue.List(vue.ListIndex, 1)

    Dim lastRow As Long, i As Long
    lastRow = ws.Cells(ws.Rows.Count, 1).End(xlUp).Row
    
    For i = 2 To lastRow
        If ws.Cells(i, 2).Value = valueContrat Then
            currentRow = i
            Exit For
        End If
    Next i
    
    With ws
        agent.Value = .Cells(i, 1).Value
        typecredit.Value = .Cells(i, 4).Value
        typeproduit.Value = .Cells(i, 5).Value
        refdos.Value = .Cells(i, 6).Value
        typesignature.Value = .Cells(i, 7).Value
        decision.Value = .Cells(i, 8).Value
        comment.Value = .Cells(i, 9).Value
        
    End With

    isEditing = True
End Sub

Private Sub recherche_Click()
    SearchData
End Sub
Sub SearchData()
    Dim ws As Worksheet
    Set ws = ThisWorkbook.Worksheets("OCAOCR")

    vue.Clear
    
    If ws.Cells(2, 1).Value = "" Then
        MsgBox "Aucune donnée trouvée.", vbInformation
        Exit Sub
    End If

    Dim lastRow As Long
    lastRow = ws.Cells(ws.Rows.Count, 1).End(xlUp).Row
    
    vue.ColumnCount = 6
    vue.ColumnHeads = True
    
    Dim searchContract As String
    searchContract = InputBox("Entrez le référence dossier :", "Recherche")

    Dim i As Long
    
    If searchContract = "" Then
        Dim dataRange As Range
        Set dataRange = ws.Range("A2:H" & lastRow)
        vue.List = dataRange.Value
        Exit Sub
    End If
    
    Dim results As Collection
    Set results = New Collection
    
    For i = 2 To lastRow
        If InStr(1, ws.Cells(i, 6).Value, searchContract, vbTextCompare) > 0 Then
            results.Add i
        End If
    Next i
    
    If results.Count = 0 Then
        MsgBox "Aucun contrat trouvé.", vbInformation
        Exit Sub
    End If
    
    Dim arr()
    ReDim arr(1 To results.Count, 1 To 12)
    
    For i = 1 To results.Count
        arr(i, 1) = ws.Cells(results(i), 1).Value
        arr(i, 2) = ws.Cells(results(i), 2).Value
        arr(i, 3) = ws.Cells(results(i), 3).Value
        arr(i, 4) = ws.Cells(results(i), 4).Value
        arr(i, 5) = ws.Cells(results(i), 5).Value
        arr(i, 6) = ws.Cells(results(i), 6).Value
            
    Next i

    vue.List = arr
End Sub
