Private Sub cboRacine_Change()
    Dim cheminACM As String
    Dim dossier As Object
    Dim sousDossier As Object
    
    cboSousDossier.Clear
    
    Set FSO = CreateObject("Scripting.FileSystemObject")
    
    If cboRacine.Value = "ACM" Then
        cheminACM = basePath & "ACM\NON CONFORME\"
        If FSO.FolderExists(cheminACM) Then
            Set dossier = FSO.GetFolder(cheminACM)
            For Each sousDossier In dossier.subFolders
                cboSousDossier.AddItem sousDossier.Name
            Next sousDossier
        End If
    ElseIf cboRacine.Value = "DIRCO" Then
        ' Pour DIRCO, on ajoute CM et CIC comme sous-dossiers
        cboSousDossier.AddItem "CM"
        cboSousDossier.AddItem "CIC"
        ' On pourra ajouter un troisième niveau plus tard si nécessaire
    ElseIf cboRacine.Value = "CONTRATHEQUE" Then
        cboSousDossier.AddItem "CONDITIONS GENERALES"
        cboSousDossier.AddItem "Conventions"
        cboSousDossier.AddItem "Document d’Information Tarifaire"
        cboSousDossier.AddItem "Granties"
        cboSousDossier.AddItem "Politique de Protection"
    Else
        cboSousDossier.AddItem "(Aucun)"
    End If
End Sub

Private Sub cmdRechercher_Click()
    Dim cheminFinal As String
    Dim dossier As Object
    Dim d As Object
    Dim sousDossier As Object
    
    If cboRacine.Value = "" Then
        MsgBox "Sélectionnez un dossier racine"
        Exit Sub
    End If
    
    Set FSO = CreateObject("Scripting.FileSystemObject")
    
    If cboRacine.Value = "ACM" Then
        If cboSousDossier.Value = "" Then
            MsgBox "Sélectionnez un type ACM"
            Exit Sub
        End If
        cheminFinal = basePath & "ACM\NON CONFORME\" & cboSousDossier.Value
        If Not FSO.FolderExists(cheminFinal) Then
            MsgBox "Dossier introuvable"
            Exit Sub
        End If
        Set dossier = FSO.GetFolder(cheminFinal)
        lstResultats.Clear
        For Each d In dossier.subFolders
            lstResultats.AddItem d.Name
            lstResultats.List(lstResultats.ListCount - 1, 1) = d.path
        Next d
    Else
        ' Pour DIRCO, nous devons parcourir les sous-catégories
        If cboRacine.Value = "DIRCO" Then
            If cboSousDossier.Value = "" Then
                MsgBox "Sélectionnez une catégorie (CM ou CIC)"
                Exit Sub
            End If
            ' On suppose que les dossiers NON CONFORME se trouvent directement sous
            ' ...\CM\FICHES CLIENTS\NON CONFORME et ...\CIC\FICHES CLIENTS\NON CONFORME
            ' On va parcourir tous les dossiers "NON CONFORME" sous la catégorie choisie.
            cheminFinal = basePath & "DIRCO\" & cboSousDossier.Value
            If Not FSO.FolderExists(cheminFinal) Then
                MsgBox "Dossier introuvable"
                Exit Sub
            End If
            Set dossier = FSO.GetFolder(cheminFinal)
            ' On appelle une fonction de recherche récursive
            Call RechercherNonConforme(dossier)
        Else
            ' Autres racines : recherche simple
            cheminFinal = basePath & cboRacine.Value
            If cboSousDossier.Value <> "" And cboSousDossier.Value <> "(Aucun)" Then
                cheminFinal = cheminFinal & "\" & cboSousDossier.Value
            End If
            If Not FSO.FolderExists(cheminFinal) Then
                MsgBox "Dossier introuvable"
                Exit Sub
            End If
            Set dossier = FSO.GetFolder(cheminFinal)
            Call RechercherNonConforme(dossier)
        End If
    End If
    
    If lstResultats.ListCount = 0 Then
        MsgBox "Aucun dossier trouvé"
    End If
End Sub

Private Sub RechercherNonConforme(ByVal dossier As Object)
    Dim sousDossier As Object
    Dim d As Object
    
    For Each sousDossier In dossier.subFolders
        If UCase(sousDossier.Name) = "NON CONFORME" Then
            For Each d In sousDossier.subFolders
                lstResultats.AddItem d.Name
                lstResultats.List(lstResultats.ListCount - 1, 1) = d.path
            Next d
        End If
        Call RechercherNonConforme(sousDossier)
    Next sousDossier
End Sub

Private Sub lstResultats_DblClick(ByVal Cancel As MSForms.ReturnBoolean)
    If lstResultats.ListIndex <> -1 Then
        Shell "explorer.exe """ & lstResultats.List(lstResultats.ListIndex, 1) & """", vbNormalFocus
    End If
End Sub

Private Sub ParcourirDossier(ByVal dossier As Object)
    ' Cette procédure semble redondante avec RechercherNonConforme
    ' Nous la conservons pour compatibilité mais elle n'est pas utilisée dans le code actuel
    Dim sousDossier As Object
    Dim categorie As Object
    Dim dossierFinal As Object
    Dim racineSelectionnee As String
    
    For Each sousDossier In dossier.subFolders
        If UCase(sousDossier.Name) = "NON CONFORME" Then
            If UCase(racineSelectionnee) = "ACM" Then
                For Each categorie In sousDossier.subFolders
                    For Each dossierFinal In categorie.subFolders
                        lstResultats.AddItem dossierFinal.Name
                        lstResultats.List(lstResultats.ListCount - 1, 1) = dossierFinal.path
                    Next dossierFinal
                Next categorie
            Else
                For Each dossierFinal In sousDossier.subFolders
                    lstResultats.AddItem dossierFinal.Name
                    lstResultats.List(lstResultats.ListCount - 1, 1) = dossierFinal.path
                Next dossierFinal
            End If
        End If
        Call ParcourirDossier(sousDossier)
    Next sousDossier
End Sub

