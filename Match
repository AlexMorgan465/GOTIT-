        MsgBox "Le dossier existe déjà à destination.", vbExclamation
        Exit Sub
    End If
    
    ' Copier
        
    Name srcPath As histoPath

    FSO.CopyFolder dossierSource, destinationFinale, True
    'FSO.DeleteFolder srcPath, True
    
    If FSO.FolderExists(destinationFinale) Then
        MsgBox "Dossier déplacé avec succès.", vbInformation
    Else
        MsgBox "Erreur lors de la copie.", vbCritical
    End If
    
        ' Journaliser
    LoAction "Déplacement", fileName, txtAgent, _
              "de NON CONFORME à TRAITES"
              
    Dim ws1 As Worksheet, ws2 As Worksheet
    Dim lastRow1 As Long, lastRow2 As Long
    Dim dict As Object
    Dim i As Long
    Dim key As String

    ' Définir les feuilles
    Set ws1 = ThisWorkbook.Sheets("SHEET_TRACE_NAME")
    Set ws2 = ThisWorkbook.Sheets("NC_LOG_ACTIONS")

    ' Dernières lignes
    lastRow1 = ws1.Cells(ws1.Rows.Count, "A").End(xlUp).row
    lastRow2 = ws2.Cells(ws2.Rows.Count, "C").End(xlUp).row

    ' Dictionnaire pour accélérer la recherche
    Set dict = CreateObject("Scripting.Dictionary")

    ' Charger les données de Sheet2 (clé = nom, valeur = date)
    For i = 2 To lastRow2 ' (suppose ligne 1 = en-têtes)
        key = Trim(ws2.Cells(i, "C").Value)
        
        If key <> "" Then
            dict(key) = ws2.Cells(i, "A").Value
        End If
    Next i

    ' Parcourir Sheet1 et comparer
    For i = 2 To lastRow1
        key = Trim(ws1.Cells(i, "A").Value)
        
        If dict.exists(key) Then
            ' Coller la date en colonne B de Sheet1
            ws1.Cells(i, "H").Value = dict(key)
            ws1.Cells(i, "E").Value = "TRAITES"
            ws1.Cells(i, "K").Value = ws1.Cells(i, "H").Value - ws1.Cells(i, "G").Value
        End If
    Next i

    MsgBox "Traitement terminé !", vbInformation
    
    Exit Sub

GestionErreur:
    MsgBox "Erreur - " & Err.Number & " - " & Err.Description, vbCritical


End Sub
Private Sub LoadFichiers_NC()
    Dim path As String
    
    lstFichiers.Clear
    
    If cboRacine = "" Or cboSousDossier = "" Then Exit Sub
    
    ' Construire le chemin selon la structure
    Dim structType As StructureType
    structType = GetDomainStructure(cmbDomaine.Value)
    
    Select Case cboRacine.Value
        Case "CONTRATHEQUE"
            path = ROOT_PATH & "\" & cboRacine.Value & "\" & cboSousDossier.Value & "\NON CONFORME"
            
        Case "ACM"
                path = ROOT_PATH & "\" & cboRacine.Value & "\NON CONFORME\" & cboSousDossier.Value
        Case Else
                path = ROOT_PATH & "\" & cboRacine.Value & "\NON CONFORME\"
    End Select
    MsgBox path
    ' Charger les fichiers
    If FolderExists(path) Then
        LoadFilesToList lstResultats, path
    Else
        lstResultats.AddItem "[DOSSIER VIDE]"
    End If
End Sub
