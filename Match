' Module-level variables
Dim currentRow As Long
Dim isEditing As Boolean   ' optional, kept from original logic

' ------------------------------------------------------------------
' Helper functions to get the correct worksheet based on cmbTraitement
' ------------------------------------------------------------------
Private Function GetTempSheet() As Worksheet
    If cmbTraitement.Value = "SOLVA" Then
        Set GetTempSheet = ThisWorkbook.Worksheets("temp_Solva")
    Else
        Set GetTempSheet = ThisWorkbook.Worksheets("temp")
    End If
End Function

Private Function GetExtractSheet() As Worksheet
    If cmbTraitement.Value = "SOLVA" Then
        Set GetExtractSheet = ThisWorkbook.Worksheets("extraction_solva")
    Else
        Set GetExtractSheet = ThisWorkbook.Worksheets("extraction")
    End If
End Function

' ------------------------------------------------------------------
' Refresh the ListView (named "vue") according to the active temp sheet
' ------------------------------------------------------------------
Private Sub RefreshListView()
    Dim ws As Worksheet
    Set ws = GetTempSheet()
    
    Dim lastRow As Long
    lastRow = ws.Cells(ws.Rows.Count, 1).End(xlUp).Row
    
    If lastRow < 2 Then
        vue.Clear
        Exit Sub
    End If
    
    Dim rng1 As Range
    Dim colCount As Integer
    
    If cmbTraitement.Value = "SOLVA" Then
        colCount = 6   ' Columns A to F in temp_Solva
        Set rng1 = ws.Range("A1:F" & lastRow)
    Else
        colCount = 9   ' Columns A to I in temp
        Set rng1 = ws.Range("A1:I" & lastRow)
    End If
    
    With vue
        .Clear
        .ColumnCount = colCount
        .List = rng1.Value
        ' Adjust column widths as needed
        .ColumnWidths = "80;80;80;80;80;80;80;80;80"
    End With
End Sub

' ------------------------------------------------------------------
' Clear all input fields
' ------------------------------------------------------------------
Sub clearform()
    cmbCredit.Value = ""
    cmbProduits.Value = ""
    txtDossier.Value = ""
    cmbSignature.Value = ""
    cmbDecision.Value = ""
    comment.Value = ""
    Solvabilité.Value = ""
    cmbDecisionSolva.Value = ""
    cmbType.Value = ""
End Sub

' ------------------------------------------------------------------
' Logging procedures
' ------------------------------------------------------------------
Sub log_Etape1()
    Dim wx As Worksheet
    Set wx = GetExtractSheet()
    
    Dim lastRow As Long, ligne As Long
    lastRow = wx.Cells(wx.Rows.Count, 1).End(xlUp).Row
    ligne = lastRow + 1
    
    With wx
        .Cells(ligne, 1).Value = Environ("USERNAME")
        .Cells(ligne, 2).Value = cmbTraitement.Value
        .Cells(ligne, 3).Value = Now
        .Cells(ligne, 5).Value = cmbCredit.Value
        .Cells(ligne, 6).Value = cmbProduits.Value
        .Cells(ligne, 7).Value = txtDossier.Value
    End With
End Sub

Sub logSolva_Etape1()
    Dim wx As Worksheet
    Set wx = ThisWorkbook.Worksheets("extraction_solva")
    
    Dim lastRow As Long, ligne As Long
    lastRow = wx.Cells(wx.Rows.Count, 1).End(xlUp).Row
    ligne = lastRow + 1
    
    With wx
        .Cells(ligne, 1).Value = Environ("USERNAME")
        .Cells(ligne, 2).Value = cmbTraitement.Value
        .Cells(ligne, 3).Value = Now
        .Cells(ligne, 5).Value = Solvabilité.Value
        .Cells(ligne, 6).Value = txtDossier.Value
    End With
End Sub

Sub log_Etape2()
    Dim wx As Worksheet
    Set wx = GetExtractSheet()
    
    ' currentRow refers to the row in the temp sheet
    ' We need to find the matching row in extraction sheet using the reference
    Dim refValue As String
    Dim tempWs As Worksheet
    Set tempWs = GetTempSheet()
    refValue = tempWs.Cells(currentRow, 7).Value   ' column G = dossier ref
    
    Dim lastRow As Long, i As Long
    lastRow = wx.Cells(wx.Rows.Count, 1).End(xlUp).Row
    Dim targetRow As Long
    targetRow = 0
    
    For i = 2 To lastRow
        If wx.Cells(i, 7).Value = refValue Then
            targetRow = i
            Exit For
        End If
    Next i
    
    If targetRow = 0 Then
        ' If not found, append as new row (should not happen normally)
        targetRow = lastRow + 1
        wx.Cells(targetRow, 1).Value = Environ("USERNAME")
        wx.Cells(targetRow, 2).Value = cmbTraitement.Value
        wx.Cells(targetRow, 3).Value = tempWs.Cells(currentRow, 3).Value
        wx.Cells(targetRow, 7).Value = refValue
    End If
    
    With wx
        .Cells(targetRow, 4).Value = Now
        .Cells(targetRow, 8).Value = cmbSignature.Value
        .Cells(targetRow, 9).Value = cmbDecision.Value
        .Cells(targetRow, 10).Value = comment.Value
        .Cells(targetRow, 11).Value = .Cells(targetRow, 4).Value - .Cells(targetRow, 3).Value
    End With
End Sub

Sub log_Etape2_Solva()
    Dim wx As Worksheet
    Set wx = ThisWorkbook.Worksheets("extraction_solva")
    
    Dim tempWs As Worksheet
    Set tempWs = GetTempSheet()
    Dim refValue As String
    refValue = tempWs.Cells(currentRow, 6).Value   ' column F = dossier ref in temp_Solva
    
    Dim lastRow As Long, i As Long
    lastRow = wx.Cells(wx.Rows.Count, 1).End(xlUp).Row
    Dim targetRow As Long
    targetRow = 0
    
    For i = 2 To lastRow
        If wx.Cells(i, 6).Value = refValue Then
            targetRow = i
            Exit For
        End If
    Next i
    
    If targetRow = 0 Then
        targetRow = lastRow + 1
        wx.Cells(targetRow, 1).Value = Environ("USERNAME")
        wx.Cells(targetRow, 2).Value = "SOLVA"
        wx.Cells(targetRow, 3).Value = tempWs.Cells(currentRow, 3).Value
        wx.Cells(targetRow, 6).Value = refValue
    End If
    
    With wx
        .Cells(targetRow, 4).Value = Now
        .Cells(targetRow, 5).Value = cmbDecisionSolva.Value
        .Cells(targetRow, 7).Value = comment.Value
        .Cells(targetRow, 8).Value = .Cells(targetRow, 4).Value - .Cells(targetRow, 3).Value
    End With
End Sub

' ------------------------------------------------------------------
' Add new record (cmb_Ajouter_Click)
' ------------------------------------------------------------------
Private Sub cmb_Ajouter_Click()
    Dim ws As Worksheet
    Set ws = GetTempSheet()
    
    Dim refValue As String
    refValue = Trim(txtDossier.Value)
    If refValue = "" Then
        MsgBox "Veuillez saisir une référence dossier.", vbExclamation
        Exit Sub
    End If
    
    Dim lastRow As Long, i As Long
    lastRow = ws.Cells(ws.Rows.Count, 1).End(xlUp).Row
    
    ' Determine column where reference is stored
    Dim refCol As Long
    If cmbTraitement.Value = "SOLVA" Then
        refCol = 6   ' column F
    Else
        refCol = 7   ' column G
    End If
    
    ' Check for duplicate reference
    For i = 2 To lastRow
        If ws.Cells(i, refCol).Value = refValue Then
            MsgBox "La référence dossier '" & refValue & "' existe déjà !", vbCritical
            Exit Sub
        End If
    Next i
    
    Dim newRow As Long
    newRow = lastRow + 1
    
    With ws
        .Cells(newRow, 1).Value = Environ("USERNAME")
        .Cells(newRow, 2).Value = cmbTraitement.Value
        .Cells(newRow, 3).Value = Now
        
        If cmbTraitement.Value = "SOLVA" Then
            .Cells(newRow, 5).Value = Solvabilité.Value
            .Cells(newRow, 6).Value = txtDossier.Value
        Else
            .Cells(newRow, 5).Value = cmbCredit.Value
            .Cells(newRow, 6).Value = cmbProduits.Value
            .Cells(newRow, 7).Value = txtDossier.Value
        End If
    End With
    
    ' Log to extraction sheet
    If cmbTraitement.Value = "SOLVA" Then
        Call logSolva_Etape1
    Else
        Call log_Etape1
    End If
    
    Call clearform
    Call RefreshListView
    MsgBox "Dossier ajouté avec succès !", vbInformation
End Sub

' ------------------------------------------------------------------
' Save modifications (cmb_Terminer_Click)
' ------------------------------------------------------------------
Private Sub cmb_Terminer_Click()
    Dim ws As Worksheet
    Set ws = GetTempSheet()
    
    If currentRow = 0 Then
        MsgBox "Veuillez d'abord rechercher et sélectionner une ligne à modifier.", vbExclamation
        Exit Sub
    End If
    
    If cmbTraitement.Value = "SOLVA" Then
        ' SOLVA case
        If cmbDecisionSolva.Value = "" Then
            MsgBox "Veuillez sélectionner une décision solvabilité."
            Exit Sub
        End If
        
        With ws
            .Cells(currentRow, 4).Value = Now
            .Cells(currentRow, 5).Value = cmbDecisionSolva.Value
            .Cells(currentRow, 7).Value = comment.Value   ' assuming comment is in column G
            .Cells(currentRow, 8).Value = .Cells(currentRow, 4).Value - .Cells(currentRow, 3).Value
        End With
        
        Call log_Etape2_Solva
    Else
        ' Normal case (OCAOCR / ETUDEINC)
        If cmbSignature.Value = "" Then
            MsgBox "Veuillez remplir l'activité."
            Exit Sub
        ElseIf cmbDecision.Value = "" Then
            MsgBox "Veuillez sélectionner le produit."
            Exit Sub
        End If
        
        With ws
            .Cells(currentRow, 4).Value = Now
            .Cells(currentRow, 8).Value = cmbSignature.Value
            .Cells(currentRow, 9).Value = cmbDecision.Value
            .Cells(currentRow, 10).Value = comment.Value
            .Cells(currentRow, 11).Value = .Cells(currentRow, 4).Value - .Cells(currentRow, 3).Value
        End With
        
        Call log_Etape2
    End If
    
    Call clearform
    Call RefreshListView
    MsgBox "Modifications enregistrées.", vbInformation
End Sub

