    LoadDomaines
    
    ' Initialiser les statuts
    cmbStatutSource.Clear
    cmbStatutSource.AddItem "A TRAITER"
    cmbStatutSource.AddItem "EN COURS"
    
    cmbStatutDestination.Clear
    cmbStatutDestination.AddItem "EN COURS"
    cmbStatutDestination.AddItem "TRAITES"
    cmbStatutDestination.AddItem "NON CONFORME"
    
    ' Valeurs par défaut
    cmbStatutSource.ListIndex = 0
    cmbStatutDestination.ListIndex = 0
    txtAgent.Value = Environ("USERNAME")
    
    ' Définir le chemin racine (à adapter si nécessaire)
    ROOT_PATH = "\\UF11-a03\eids-eaa-pdf-statiques\Accessibilité\"
    basePath = ROOT_PATH   ' pour cohérence avec la deuxième partie
    
    ' Remplir la liste des racines pour l'onglet "Recherche"
    cboRacine.AddItem "ACM"
    cboRacine.AddItem "Bouygues telecom"
    cboRacine.AddItem "CIC CIB ASSET SERVICING"
    cboRacine.AddItem "CONTRATHEQUE"
    cboRacine.AddItem "DIRCO"
    
    ' Configuration des listes
    lstResultats.ColumnCount = 2
    lstResultats.ColumnWidths = "300 pt;0 pt"
    
    ' --- Nouveau : Configuration du combobox de sous-catégorie (pour DIRCO) ---
    cmbSousCategorie.Visible = False
    cmbSousCategorie.Enabled = False
    cmbSousDomaine.Visible = True   ' par défaut
End Sub

' --------------------------------------------------------------
' Chargement des domaines depuis la racine
' --------------------------------------------------------------
Private Sub LoadDomaines()
    Dim col As Collection
    Dim item As Variant
    
    cmbDomaine.Clear
    Set col = GetSubFolders(ROOT_PATH)
    
    If col.Count = 0 Then
        cmbDomaine.AddItem "[AUCUN DOMAINE]"
    Else
        For Each item In col
            cmbDomaine.AddItem item
        Next
    End If
End Sub

' --------------------------------------------------------------
' Quand le domaine change
' --------------------------------------------------------------
Private Sub cmbDomaine_Change()
    Dim col As Collection
    Dim item As Variant
    
    cmbSousCategorie.Clear
    cmbSousDomaine.Clear
    lstFichiers.Clear
    
    If cmbDomaine.Value = "" Or cmbDomaine.Value Like "[*]*" Then Exit Sub
    
    ' --- Gestion spéciale pour DIRCO (nouvelle hiérarchie) ---
    If cmbDomaine.Value = "DIRCO" Then
        ' Afficher et remplir la sous-catégorie (CM / CIC)
        cmbSousCategorie.AddItem "CM"
        cmbSousCategorie.AddItem "CIC"
        cmbSousCategorie.Enabled = True
        cmbSousCategorie.Visible = True
        cmbSousCategorie.ListIndex = 0   ' sélectionne le premier
        ' Le sous-domaine (FICHES CLIENTS) sera chargé après le choix de la catégorie
        cmbSousDomaine.Enabled = False
        cmbSousDomaine.Visible = False
        Exit Sub
    End If
    
    ' --- Pour les autres domaines, comportement original ---
    cmbSousCategorie.Visible = False
    cmbSousCategorie.Enabled = False
    cmbSousDomaine.Visible = True
    
    ' Déterminer la structure
    Dim structType As StructureType
    structType = GetDomainStructure(cmbDomaine.Value)
    
    Select Case structType
        Case SIMPLE
            cmbSousDomaine.AddItem "[PAS DE SOUS-DOMAINE]"
            cmbSousDomaine.Enabled = False
            
        Case Complex
            Set col = GetNonStatutFolders(ROOT_PATH & "\" & cmbDomaine.Value)
            If col.Count > 0 Then
                For Each item In col
                    cmbSousDomaine.AddItem item
                Next
            Else
                cmbSousDomaine.AddItem "[AUCUNE CATEGORIE]"
            End If
            cmbSousDomaine.Enabled = True
            
        Case THREE_LEVEL ' ACM
            Set col = GetSubFolders(ROOT_PATH & "\" & cmbDomaine.Value & "\A TRAITER")
            If col.Count > 0 Then
                For Each item In col
                    cmbSousDomaine.AddItem item
                Next
            Else
                cmbSousDomaine.AddItem "[AUCUN TYPE]"
            End If
            cmbSousDomaine.Enabled = True
    End Select
    
    If cmbSousDomaine.ListCount > 0 Then
        cmbSousDomaine.ListIndex = 0
    End If
End Sub

' --------------------------------------------------------------
' Quand la sous-catégorie DIRCO (CM/CIC) change
' --------------------------------------------------------------
Private Sub cmbSousCategorie_Change()
    If cmbDomaine.Value <> "DIRCO" Then Exit Sub
    If cmbSousCategorie.ListIndex = -1 Then Exit Sub
    
    cmbSousDomaine.Clear
    ' Ici, nous chargeons le sous-domaine "FICHES CLIENTS" (fixe pour l'instant)
    ' Si d'autres sous-dossiers peuvent exister, utilisez GetSubFolders
    cmbSousDomaine.AddItem "FICHES CLIENTS"
    cmbSousDomaine.Enabled = True
    cmbSousDomaine.Visible = True
    cmbSousDomaine.ListIndex = 0
End Sub

' --------------------------------------------------------------
' Quand le sous-domaine change (pour les domaines autres que DIRCO)
' --------------------------------------------------------------
Private Sub cmbSousDomaine_Change()
    ' Pour DIRCO, ce changement est déjà géré par cmbSousCategorie_Change,
    ' donc on recharge les fichiers ici aussi
    If cmbDomaine.Value = "DIRCO" Then
        LoadFichiers
    Else
        lstFichiers.Clear
    End If
End Sub

