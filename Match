' --- Enumerations ---
Private Enum StructureType
    SIMPLE = 0
    Complex = 1
    THREE_LEVEL = 2
End Enum

' --- Form-level variables ---
Private FSO As Object
Private basePath As String

' ============================================================================
' Initialisation
' ============================================================================

Private Sub UserForm_Initialize()
    ' Center form
    Me.StartUpPosition = 0
    Me.Left = Application.Left + (Application.Width - Me.Width) / 2
    Me.Top = Application.Top + (Application.Height - Me.Height) / 2
    
    Set FSO = CreateObject("Scripting.FileSystemObject")
    basePath = ROOT_PATH
    
    ' Load root combobox
    cboRacine.AddItem "ACM"
    cboRacine.AddItem "Bouygues telecom"
    cboRacine.AddItem "CIC CIB ASSET SERVICING"
    cboRacine.AddItem "CONTRATHEQUE"
    cboRacine.AddItem "DIRCO"
    
    ' Load domains
    LoadDomaines
    
    ' Status comboboxes
    With cmbStatutSource
        .Clear
        .AddItem "A TRAITER"
        .AddItem "EN COURS"
        .ListIndex = 0
    End With
    
    With cmbStatutDestination
        .Clear
        .AddItem "EN COURS"
        .AddItem "TRAITES"
        .AddItem "NON CONFORME"
        .ListIndex = 0
    End With
    
    ' Default agent
    txtAgent.Value = Environ("USERNAME")
    
    ' List columns
    lstResultats.ColumnCount = 2
    lstResultats.ColumnWidths = "300 pt;0 pt"
End Sub

Private Sub LoadDomaines()
    Dim col As Collection
    Dim item As Variant
    
    cmbDomaine.Clear
    Set col = GetSubFolders(ROOT_PATH)
    
    If col.Count = 0 Then
        cmbDomaine.AddItem "[AUCUN DOMAINE]"
    Else
        For Each item In col
            cmbDomaine.AddItem item
        Next item
    End If
End Sub

' ============================================================================
' Domain & subdomain logic
' ============================================================================

Private Function GetDomainStructure(domain As String) As StructureType
    Select Case domain
        Case "ACM":                 GetDomainStructure = THREE_LEVEL
        Case "DIRCO", "CONTRATHEQUE": GetDomainStructure = Complex
        Case Else:                  GetDomainStructure = SIMPLE
    End Select
End Function

Private Function GetSubFolders(parentPath As String) As Collection
    Dim col As New Collection
    Dim folder As Object
    
    If FSO.FolderExists(parentPath) Then
        For Each folder In FSO.GetFolder(parentPath).SubFolders
            col.Add folder.Name
        Next folder
    End If
    Set GetSubFolders = col
End Function

Private Function GetNonStatutFolders(parentPath As String) As Collection
    ' Returns subfolders that are NOT status folders (A TRAITER, EN COURS, TRAITES, NON CONFORME)
    Dim col As New Collection
    Dim folder As Object
    Dim statusFolders As Variant
    Dim skip As Boolean
    Dim sf As Variant
    
    statusFolders = Array("A TRAITER", "EN COURS", "TRAITES", "NON CONFORME")
    
    If FSO.FolderExists(parentPath) Then
        For Each folder In FSO.GetFolder(parentPath).SubFolders
            skip = False
            For Each sf In statusFolders
                If folder.Name = sf Then skip = True: Exit For
            Next sf
            If Not skip Then col.Add folder.Name
        Next folder
    End If
    Set GetNonStatutFolders = col
End Function

Private Function FolderExists(path As String) As Boolean
    FolderExists = FSO.FolderExists(path)
End Function

Private Sub CreateFolderIfNotExists(path As String)
    If Not FSO.FolderExists(path) Then
        FSO.CreateFolder path
    End If
End Sub

Private Sub LoadFilesToList(lst As MSForms.ListBox, folderPath As String)
    Dim file As Object
    lst.Clear
    If FSO.FolderExists(folderPath) Then
        For Each file In FSO.GetFolder(folderPath).Files
            lst.AddItem file.Name
        Next file
        If lst.ListCount = 0 Then lst.AddItem "[DOSSIER VIDE]"
    Else
        lst.AddItem "[DOSSIER VIDE]"
    End If
End Sub

' ============================================================================
' Domain / subdomain change events
' ============================================================================

Private Sub cmbDomaine_Change()
    Dim col As Collection
    Dim item As Variant
    Dim structType As StructureType
    
    cmbSousDomaine.Clear
    lstFichiers.Clear
    
    If cmbDomaine.Value = "" Or cmbDomaine.Value Like "[*]*" Then Exit Sub
    
    structType = GetDomainStructure(cmbDomaine.Value)
    
    Select Case structType
        Case SIMPLE
            cmbSousDomaine.AddItem "[PAS DE SOUS-DOMAINE]"
            cmbSousDomaine.Enabled = False
            
        Case Complex
            Set col = GetNonStatutFolders(ROOT_PATH & "\" & cmbDomaine.Value)
            If col.Count > 0 Then
                For Each item In col
                    cmbSousDomaine.AddItem item
                Next item
            Else
                cmbSousDomaine.AddItem "[AUCUNE CATEGORIE]"
            End If
            cmbSousDomaine.Enabled = True
            
        Case THREE_LEVEL   ' ACM
            Set col = GetSubFolders(ROOT_PATH & "\" & cmbDomaine.Value & "\A TRAITER")
            If col.Count > 0 Then
                For Each item In col
                    cmbSousDomaine.AddItem item
                Next item
            Else
                cmbSousDomaine.AddItem "[AUCUN TYPE]"
            End If
            cmbSousDomaine.Enabled = True
    End Select
    
    If cmbSousDomaine.ListCount > 0 Then cmbSousDomaine.ListIndex = 0
End Sub

Private Sub cmbSousDomaine_Change()
    lstFichiers.Clear
    LoadFichiers
End Sub

Private Sub cmbStatutSource_Change()
    LoadFichiers
End Sub

Private Sub LoadFichiers()
    Dim path As String
    Dim structType As StructureType
    
    lstFichiers.Clear
    If cmbDomaine = "" Or cmbStatutSource = "" Then Exit Sub
    
    structType = GetDomainStructure(cmbDomaine.Value)
    
    Select Case structType
        Case SIMPLE
            path = ROOT_PATH & "\" & cmbDomaine.Value & "\" & cmbStatutSource.Value
            
        Case Complex
            If cmbSousDomaine.Value = "" Or cmbSousDomaine.Value Like "[*]*" Then Exit Sub
            path = ROOT_PATH & "\" & cmbDomaine.Value & "\" & cmbSousDomaine.Value & "\" & cmbStatutSource.Value
            
        Case THREE_LEVEL   ' ACM
            If cmbSousDomaine.Value = "" Or cmbSousDomaine.Value Like "[*]*" Then Exit Sub
            path = ROOT_PATH & "\" & cmbDomaine.Value & "\" & cmbStatutSource.Value & "\" & cmbSousDomaine.Value
    End Select
    
    If FolderExists(path) Then
        LoadFilesToList lstFichiers, path
    Else
        lstFichiers.AddItem "[DOSSIER VIDE]"
    End If
End Sub

' ============================================================================
' Actions : Move from A TRAITER -> EN COURS
' ============================================================================

Private Sub cmdDeplacer_Click()
    Dim srcPath As String, dstPath As String
    Dim fileName As String
    Dim structType As StructureType
    
    If lstFichiers.ListIndex = -1 Or lstFichiers.Value = "[DOSSIER VIDE]" Then
        MsgBox "Sélectionnez un fichier", vbExclamation
        Exit Sub
    End If
    If Trim(txtAgent.Value) = "" Then
        MsgBox "Agent requis", vbCritical
        Exit Sub
    End If
    
    fileName = lstFichiers.Value
    structType = GetDomainStructure(cmbDomaine.Value)
    
    ' --- Source path ---
    Select Case structType
        Case SIMPLE
            srcPath = ROOT_PATH & "\" & cmbDomaine.Value & "\" & cmbStatutSource.Value
        Case Complex
            srcPath = ROOT_PATH & "\" & cmbDomaine.Value & "\" & cmbSousDomaine.Value & "\" & cmbStatutSource.Value
        Case THREE_LEVEL
            srcPath = ROOT_PATH & "\" & cmbDomaine.Value & "\" & cmbStatutSource.Value & "\" & cmbSousDomaine.Value
    End Select
    srcPath = srcPath & "\" & fileName
    
    ' --- Destination path (always EN COURS) ---
    Select Case structType
        Case SIMPLE
            dstPath = ROOT_PATH & "\" & cmbDomaine.Value & "\EN COURS"
        Case Complex
            dstPath = ROOT_PATH & "\" & cmbDomaine.Value & "\" & cmbSousDomaine.Value & "\EN COURS"
        Case THREE_LEVEL
            dstPath = ROOT_PATH & "\" & cmbDomaine.Value & "\EN COURS\" & cmbSousDomaine.Value
    End Select
    CreateFolderIfNotExists dstPath
    dstPath = dstPath & "\" & fileName
    
    ' --- Move ---
    On Error GoTo ErrorHandler
    Name srcPath As dstPath
    
    ' Log action
    LogAction "Déplacement", fileName, cmbDomaine.Value, cmbSousDomaine.Value, _
              txtAgent.Value, txtCommentaire.Value, cmbStatutSource.Value & " ? EN COURS"
    
    ' Refresh
    LoadFichiers
    txtCommentaire.Value = ""
    MsgBox "Fichier déplacé vers EN COURS", vbInformation
    Exit Sub
    
ErrorHandler:
    MsgBox "Erreur déplacement : " & Err.Description, vbCritical
End Sub

' ============================================================================
' Actions : Move from EN COURS -> TRAITES / NON CONFORME
' ============================================================================

Private Sub CommandButton1_Click()
    Dim srcPath As String, dstPath As String
    Dim fileName As String
    Dim finalStatus As String
    Dim structType As StructureType
    Dim wsTrace As Worksheet
    
    If lstFichiers.ListIndex = -1 Or lstFichiers.Value = "[DOSSIER VIDE]" Then
        MsgBox "Sélectionnez un fichier", vbExclamation
        Exit Sub
    End If
    
    ' Determine final status
    If optTraites.Value Then
        finalStatus = "TRAITES"
    ElseIf optNonConforme.Value Then
        finalStatus = "NON CONFORME"
    Else
        MsgBox "Veuillez sélectionner TRAITES ou NON CONFORME", vbExclamation
        Exit Sub
    End If
    
    If finalStatus = "NON CONFORME" And Trim(txtCommentaire.Value) = "" Then
        MsgBox "Un commentaire est requis pour NON CONFORME", vbExclamation
        Exit Sub
    End If
    
    fileName = lstFichiers.Value
    structType = GetDomainStructure(cmbDomaine.Value)
    
    ' --- Source path (EN COURS) ---
    Select Case structType
        Case SIMPLE
            srcPath = ROOT_PATH & "\" & cmbDomaine.Value & "\EN COURS"
        Case Complex
            srcPath = ROOT_PATH & "\" & cmbDomaine.Value & "\" & cmbSousDomaine.Value & "\EN COURS"
        Case THREE_LEVEL
            srcPath = ROOT_PATH & "\" & cmbDomaine.Value & "\EN COURS\" & cmbSousDomaine.Value
    End Select
    srcPath = srcPath & "\" & fileName
    
    ' --- Destination path (TRAITES or NON CONFORME) ---
    Select Case structType
        Case SIMPLE
            dstPath = ROOT_PATH & "\" & cmbDomaine.Value & "\" & finalStatus
        Case Complex
            dstPath = ROOT_PATH & "\" & cmbDomaine.Value & "\" & cmbSousDomaine.Value & "\" & finalStatus
        Case THREE_LEVEL
            dstPath = ROOT_PATH & "\" & cmbDomaine.Value & "\" & finalStatus & "\" & cmbSousDomaine.Value
    End Select
    CreateFolderIfNotExists dstPath
    dstPath = dstPath & "\" & fileName
    
    ' --- Move ---
    On Error GoTo ErrorHandler
    Name srcPath As dstPath
    
    ' Log action
    LogAction "Déplacement", fileName, cmbDomaine.Value, cmbSousDomaine.Value, _
              txtAgent.Value, txtCommentaire.Value, "EN COURS ? " & finalStatus
    
    ' Refresh trace sheet
    RefreshTraceSheet
    
    ' Refresh list
    LoadFichiers
    txtCommentaire.Value = ""
    MsgBox "Fichier déplacé vers " & finalStatus, vbInformation
    Exit Sub
    
ErrorHandler:
    MsgBox "Erreur : " & Err.Description, vbCritical
End Sub

' ============================================================================
' Trace generation from LOG_ACTIONS to SHEET_TRACE_NAME
' ============================================================================

Private Sub CommandButton3_Click()
    RefreshTraceSheet
    MsgBox "Trace générée avec succès", vbInformation
End Sub

Private Sub RefreshTraceSheet()
    Dim wsLog As Worksheet, wsTrace As Worksheet
    Dim lastRow As Long, i As Long, outputRow As Long
    Dim fileName As String, Domaine As String, SousDomaine As String, agentName As String
    Dim startDate As Variant, endDate As Variant, details As String, status As String
    Dim comment As String, parts() As String
    
    Set wsLog = ThisWorkbook.Sheets("LOG_ACTIONS")
    Set wsTrace = ThisWorkbook.Sheets("SHEET_TRACE_NAME")
    
    ' Clear old data (keep headers)
    wsTrace.Rows("2:" & wsTrace.Rows.Count).ClearContents
    
    lastRow = wsLog.Cells(wsLog.Rows.Count, "A").End(xlUp).Row
    outputRow = 2
    i = 2   ' start after header
    
    Do While i <= lastRow
        ' First row (A TRAITER -> EN COURS)
        fileName = wsLog.Cells(i, 3).Value
        Domaine = wsLog.Cells(i, 4).Value
        SousDomaine = wsLog.Cells(i, 7).Value
        agentName = wsLog.Cells(i, 5).Value
        startDate = wsLog.Cells(i, 1).Value
        comment = wsLog.Cells(i + 1, 8).Value
        
        ' Second row (EN COURS -> TRAITES/NON CONFORME)
        If i + 1 <= lastRow Then
            endDate = wsLog.Cells(i + 1, 1).Value
            details = wsLog.Cells(i + 1, 6).Value
            
            ' Extract last word after "?"
            If InStr(details, "?") > 0 Then
                parts = Split(details, "?")
                status = Trim(parts(UBound(parts)))
            Else
                status = details
            End If
            
            ' Write to trace sheet
            wsTrace.Cells(outputRow, 1).Value = fileName
            wsTrace.Cells(outputRow, 2).Value = Domaine
            wsTrace.Cells(outputRow, 3).Value = SousDomaine
            wsTrace.Cells(outputRow, 4).Value = status
            wsTrace.Cells(outputRow, 5).Value = startDate
            wsTrace.Cells(outputRow, 6).Value = endDate
            wsTrace.Cells(outputRow, 7).Value = agentName
            wsTrace.Cells(outputRow, 8).Value = endDate - startDate
            wsTrace.Cells(outputRow, 9).Value = comment
            
            outputRow = outputRow + 1
        End If
        
        i = i + 2   ' jump to next pair
    Loop
End Sub

' ============================================================================
' Logging helper
' ============================================================================

Private Sub LogAction(action As String, fileName As String, domaine As String, _
                      sousDomaine As String, agent As String, comment As String, details As String)
    Dim wsLog As Worksheet
    Dim nextRow As Long
    
    Set wsLog = ThisWorkbook.Sheets("LOG_ACTIONS")
    nextRow = wsLog.Cells(wsLog.Rows.Count, "A").End(xlUp).Row + 1
    
    With wsLog
        .Cells(nextRow, 1).Value = Now       ' Date
        .Cells(nextRow, 2).Value = action
        .Cells(nextRow, 3).Value = fileName
        .Cells(nextRow, 4).Value = domaine
        .Cells(nextRow, 5).Value = agent
        .Cells(nextRow, 6).Value = details
        .Cells(nextRow, 7).Value = sousDomaine
        .Cells(nextRow + 1, 8).Value = comment   ' comment on next row (as per original)
    End With
End Sub

' ============================================================================
' Recherche des dossiers NON CONFORME
' ============================================================================

Private Sub cboRacine_Change()
    Dim cheminACM As String
    Dim dossier As Object, sousDossier As Object
    
    cboSousDossier.Clear
    
    Select Case cboRacine.Value
        Case "ACM"
            cheminACM = basePath & "ACM\NON CONFORME\"
            If FSO.FolderExists(cheminACM) Then
                Set dossier = FSO.GetFolder(cheminACM)
                For Each sousDossier In dossier.SubFolders
                    cboSousDossier.AddItem sousDossier.Name
                Next sousDossier
            End If
            
        Case "DIRCO"
            cboSousDossier.AddItem "FICHES CLIENTS"
            
        Case "CONTRATHEQUE"
            cboSousDossier.AddItem "CONDITIONS GENERALES"
            cboSousDossier.AddItem "Conventions"
            cboSousDossier.AddItem "Document d’Information Tarifaire"
            cboSousDossier.AddItem "Granties"
            cboSousDossier.AddItem "Politique de Protection"
            
        Case Else
            cboSousDossier.AddItem "(Aucun)"
    End Select
End Sub

Private Sub cmdRechercher_Click()
    Dim cheminFinal As String
    Dim dossier As Object
    
    If cboRacine.Value = "" Then
        MsgBox "Sélectionnez un dossier racine", vbExclamation
        Exit Sub
    End If
    
    lstResultats.Clear
    
    ' Build base path
    cheminFinal = basePath & cboRacine.Value
    If cboSousDossier.Value <> "" And cboSousDossier.Value <> "(Aucun)" Then
        cheminFinal = cheminFinal & "\" & cboSousDossier.Value
    End If
    
    If Not FSO.FolderExists(cheminFinal) Then
        MsgBox "Dossier introuvable", vbExclamation
        Exit Sub
    End If
    
    Set dossier = FSO.GetFolder(cheminFinal)
    SearchNonConformeFolders dossier
    
    If lstResultats.ListCount = 0 Then
        MsgBox "Aucun dossier NON CONFORME trouvé"
    End If
End Sub

Private Sub SearchNonConformeFolders(ByVal dossier As Object)
    Dim subFolder As Object, innerFolder As Object
    
    For Each subFolder In dossier.SubFolders
        If UCase(subFolder.Name) = "NON CONFORME" Then
            For Each innerFolder In subFolder.SubFolders
                lstResultats.AddItem innerFolder.Name
                lstResultats.List(lstResultats.ListCount - 1, 1) = innerFolder.Path
            Next innerFolder
        End If
        ' Recursive search
        SearchNonConformeFolders subFolder
    Next subFolder
End Sub

Private Sub lstResultats_DblClick(ByVal Cancel As MSForms.ReturnBoolean)
    If lstResultats.ListIndex <> -1 Then
        Shell "explorer.exe """ & lstResultats.List(lstResultats.ListIndex, 1) & """", vbNormalFocus
    End If
End Sub

' ============================================================================
' Move from NON CONFORME to TRAITES
' ============================================================================

Private Sub CommandButton2_Click()
    Dim srcPath As String, dstPath As String
    Dim folderName As String
    
    If lstResultats.ListIndex = -1 Then
        MsgBox "Sélectionnez un dossier", vbExclamation
        Exit Sub
    End If
    
    ' Source = selected folder (full path stored in column 2)
    srcPath = lstResultats.List(lstResultats.ListIndex, 1)
    If Not FSO.FolderExists(srcPath) Then
        MsgBox "Le dossier source n'existe plus", vbExclamation
        Exit Sub
    End If
    
    folderName = lstResultats.Value
    
    ' Build destination path based on root selection
    Select Case cboRacine.Value
        Case "DIRCO", "CONTRATHEQUE"
            dstPath = basePath & cboRacine.Value & "\" & cboSousDossier.Value & "\TRAITES"
        Case "ACM"
            dstPath = basePath & "ACM\TRAITES\" & cboSousDossier.Value
        Case Else
            dstPath = basePath & cboRacine.Value & "\TRAITES"
    End Select
    
    CreateFolderIfNotExists dstPath
    dstPath = dstPath & "\" & folderName
    
    ' Move (copy then delete original)
    On Error GoTo ErrorHandler
    FSO.CopyFolder srcPath, dstPath, True
    FSO.DeleteFolder srcPath, True
    
    ' Log action
    LogAction "Déplacement NON CONFORME -> TRAITES", folderName, cboRacine.Value, _
              cboSousDossier.Value, txtAgent.Value, "", "NON CONFORME ? TRAITES"
    
    ' Refresh list
    cmdRechercher_Click
    MsgBox "Dossier déplacé vers TRAITES", vbInformation
    Exit Sub
    
ErrorHandler:
    MsgBox "Erreur : " & Err.Description, vbCritical
End Sub

