Option Explicit

' --- Constantes chemins ---
Private Const ROOT_PATH As String = "\\UF11-a03\eids-eaa-pdf-statiques\Accessibilité\"
Private Const HISTO_PATH As String = "\\uf11pu01\ACCESSIBILITÉ_CONSEILLERS\ACCESSIBILITE\Historique\"

' --- Statuts (évite les chaînes magiques) ---
Private Const STATUT_A_TRAITER As String = "A TRAITER"
Private Const STATUT_EN_COURS As String = "EN COURS"
Private Const STATUT_TRAITES As String = "TRAITES"
Private Const STATUT_NON_CONFORME As String = "NON CONFORME"

' --- Types de structure ---
Private Enum StructureType
    SIMPLE = 0
    Complex = 1
    THREE_LEVEL = 2
    DIRCO_SPECIAL = 3
End Enum

' --- Variables de formulaire ---
Private FSO As Object
Private basePath As String

' ============================================================================
' INITIALISATION
' ============================================================================

Private Sub UserForm_Initialize()
    ' Centrage
    Me.StartUpPosition = 0
    Me.Left = Application.Left + (Application.Width - Me.Width) / 2
    Me.Top = Application.Top + (Application.Height - Me.Height) / 2
    
    Set FSO = CreateObject("Scripting.FileSystemObject")
    basePath = ROOT_PATH
    
    ' Vérifier / créer les feuilles nécessaires
    Call CheckOrCreateSheets
    
    ' Remplir combobox racine (recherche NON CONFORME)
    With cboRacine
        .Clear
        .AddItem "ACM"
        .AddItem "Bouygues telecom"
        .AddItem "CIC CIB ASSET SERVICING"
        .AddItem "CONTRATHEQUE"
        .AddItem "DIRCO"
        .ListIndex = 0
    End With
    
    ' Domaines (workflow principal)
    Call LoadDomaines
    
    ' Statuts source/destination
    With cmbStatutSource
        .Clear
        .AddItem STATUT_A_TRAITER
        .AddItem STATUT_EN_COURS
        .ListIndex = 0
    End With
    With cmbStatutDestination
        .Clear
        .AddItem STATUT_EN_COURS
        .AddItem STATUT_TRAITES
        .AddItem STATUT_NON_CONFORME
        .ListIndex = 0
    End With
    
    ' Agent par défaut
    txtAgent.Value = Environ("USERNAME")
    
    ' Colonnes de la liste des résultats (recherche NON CONFORME)
    lstResultats.ColumnCount = 2
    lstResultats.ColumnWidths = "250 pt;0 pt"
    
    ' Initialiser l'affichage des fichiers
    Call LoadFichiers
End Sub

Private Sub CheckOrCreateSheets()
    Dim ws As Worksheet
    On Error Resume Next
    Set ws = ThisWorkbook.Sheets("LOG_ACTIONS")
    If ws Is Nothing Then
        Set ws = ThisWorkbook.Sheets.Add(After:=ThisWorkbook.Sheets(ThisWorkbook.Sheets.Count))
        ws.Name = "LOG_ACTIONS"
        ws.Range("A1:H1").Value = Array("Date", "Action", "Fichier", "Domaine", "Agent", "Details", "SousDomaine", "Commentaire")
        ws.Columns("A:H").AutoFit
    End If
    
    Set ws = Nothing
    Set ws = ThisWorkbook.Sheets("SHEET_TRACE_NAME")
    If ws Is Nothing Then
        Set ws = ThisWorkbook.Sheets.Add(After:=ThisWorkbook.Sheets(ThisWorkbook.Sheets.Count))
        ws.Name = "SHEET_TRACE_NAME"
        ws.Range("A1:I1").Value = Array("Fichier", "Domaine", "SousDomaine", "Statut final", "Date début", "Date fin", "Agent", "Délai (jours)", "Commentaire")
        ws.Columns("A:I").AutoFit
    End If
    On Error GoTo 0
End Sub

Private Sub LoadDomaines()
    Dim col As Collection
    Dim item As Variant
    
    cmbDomaine.Clear
    Set col = GetSubFolders(ROOT_PATH)
    
    If col.Count = 0 Then
        cmbDomaine.AddItem "[AUCUN DOMAINE]"
    Else
        For Each item In col
            cmbDomaine.AddItem item
        Next item
    End If
End Sub

' ============================================================================
' GESTION DES STRUCTURES DE DOSSIERS
' ============================================================================

Private Function GetDomainStructure(domain As String) As StructureType
    Select Case domain
        Case "ACM":                 GetDomainStructure = THREE_LEVEL
        Case "DIRCO":               GetDomainStructure = DIRCO_SPECIAL
        Case "CONTRATHEQUE":        GetDomainStructure = Complex
        Case Else:                  GetDomainStructure = SIMPLE
    End Select
End Function

Private Function GetSubFolders(parentPath As String) As Collection
    Dim col As New Collection
    Dim folder As Object
    
    If FSO.FolderExists(parentPath) Then
        For Each folder In FSO.GetFolder(parentPath).subFolders
            col.Add folder.Name
        Next folder
    End If
    Set GetSubFolders = col
End Function

Private Function GetNonStatutFolders(parentPath As String) As Collection
    ' Retourne les sous-dossiers qui ne sont pas des dossiers de statut
    Dim col As New Collection
    Dim folder As Object
    Dim statusFolders As Variant
    Dim skip As Boolean
    Dim sf As Variant
    
    statusFolders = Array(STATUT_A_TRAITER, STATUT_EN_COURS, STATUT_TRAITES, STATUT_NON_CONFORME)
    
    If FSO.FolderExists(parentPath) Then
        For Each folder In FSO.GetFolder(parentPath).subFolders
            skip = False
            For Each sf In statusFolders
                If folder.Name = sf Then skip = True: Exit For
            Next sf
            If Not skip Then col.Add folder.Name
        Next folder
    End If
    Set GetNonStatutFolders = col
End Sub

Private Sub CreateFolderIfNotExists(path As String)
    If Not FSO.FolderExists(path) Then
        FSO.CreateFolder path
    End If
End Sub

Private Sub LoadFilesToList(lst As MSForms.ListBox, folderPath As String)
    Dim file As Object
    lst.Clear
    If FSO.FolderExists(folderPath) Then
        For Each file In FSO.GetFolder(folderPath).Files
            lst.AddItem file.Name
        Next file
        If lst.ListCount = 0 Then lst.AddItem "[DOSSIER VIDE]"
    Else
        lst.AddItem "[DOSSIER VIDE]"
    End If
End Sub

' ============================================================================
' ÉVÉNEMENTS WORKFLOW PRINCIPAL
' ============================================================================

Private Sub cmbDomaine_Change()
    Dim col As Collection
    Dim item As Variant
    Dim structType As StructureType
    
    cmbSousDomaine.Clear
    lstFichiers.Clear
    
    If cmbDomaine.Value = "" Or cmbDomaine.Value Like "[*]*" Then Exit Sub
    
    structType = GetDomainStructure(cmbDomaine.Value)
    
    Select Case structType
        Case SIMPLE
            cmbSousDomaine.AddItem "[PAS DE SOUS-DOMAINE]"
            cmbSousDomaine.Enabled = False
            
        Case Complex   ' CONTRATHEQUE
            Set col = GetNonStatutFolders(ROOT_PATH & "\" & cmbDomaine.Value)
            If col.Count > 0 Then
                For Each item In col
                    cmbSousDomaine.AddItem item
                Next item
            Else
                cmbSousDomaine.AddItem "[AUCUNE CATEGORIE]"
            End If
            cmbSousDomaine.Enabled = True
            
        Case THREE_LEVEL   ' ACM
            Set col = GetSubFolders(ROOT_PATH & "\" & cmbDomaine.Value & "\" & STATUT_A_TRAITER)
            If col.Count > 0 Then
                For Each item In col
                    cmbSousDomaine.AddItem item
                Next item
            Else
                cmbSousDomaine.AddItem "[AUCUN TYPE]"
            End If
            cmbSousDomaine.Enabled = True
            
        Case DIRCO_SPECIAL
            Set col = GetNonStatutFolders(ROOT_PATH & "\" & cmbDomaine.Value)
            If col.Count > 0 Then
                For Each item In col
                    cmbSousDomaine.AddItem item
                Next item
            Else
                cmbSousDomaine.AddItem "[AUCUN SOUS-DOMAINE]"
            End If
            cmbSousDomaine.Enabled = True
    End Select
    
    If cmbSousDomaine.ListCount > 0 Then cmbSousDomaine.ListIndex = 0
End Sub

Private Sub cmbSousDomaine_Change()
    LoadFichiers
End Sub

Private Sub cmbStatutSource_Change()
    LoadFichiers
End Sub

Private Sub LoadFichiers()
    Dim path As String
    Dim structType As StructureType
    
    lstFichiers.Clear
    If cmbDomaine = "" Or cmbStatutSource = "" Then Exit Sub
    
    structType = GetDomainStructure(cmbDomaine.Value)
    
    Select Case structType
        Case SIMPLE
            path = ROOT_PATH & "\" & cmbDomaine.Value & "\" & cmbStatutSource.Value
            
        Case Complex
            If cmbSousDomaine.Value = "" Or cmbSousDomaine.Value Like "[*]*" Then Exit Sub
            path = ROOT_PATH & "\" & cmbDomaine.Value & "\" & cmbSousDomaine.Value & "\" & cmbStatutSource.Value
            
        Case THREE_LEVEL
            If cmbSousDomaine.Value = "" Or cmbSousDomaine.Value Like "[*]*" Then Exit Sub
            path = ROOT_PATH & "\" & cmbDomaine.Value & "\" & cmbStatutSource.Value & "\" & cmbSousDomaine.Value
            
        Case DIRCO_SPECIAL
            If cmbSousDomaine.Value = "" Or cmbSousDomaine.Value Like "[*]*" Then Exit Sub
            path = ROOT_PATH & "\" & cmbDomaine.Value & "\" & cmbSousDomaine.Value & "\FICHES CLIENTS\" & cmbStatutSource.Value
    End Select
    
    If FSO.FolderExists(path) Then
        LoadFilesToList lstFichiers, path
    Else
        lstFichiers.AddItem "[DOSSIER VIDE]"
    End If
End Sub

' ------------------------------------------------------------------
' Déplacement A TRAITER → EN COURS
' ------------------------------------------------------------------
Private Sub cmdDeplacer_Click()
    Dim srcPath As String, dstPath As String
    Dim fileName As String
    Dim structType As StructureType
    
    If lstFichiers.ListIndex = -1 Or lstFichiers.Value = "[DOSSIER VIDE]" Then
        MsgBox "Veuillez sélectionner un fichier valide.", vbExclamation
        Exit Sub
    End If
    If Trim(txtAgent.Value) = "" Then
        MsgBox "Le nom de l'agent est requis.", vbCritical
        Exit Sub
    End If
    If cmbStatutSource.Value <> STATUT_A_TRAITER Then
        MsgBox "Cette action n'est possible que depuis le statut 'A TRAITER'.", vbExclamation
        Exit Sub
    End If
    
    fileName = lstFichiers.Value
    structType = GetDomainStructure(cmbDomaine.Value)
    
    ' --- Chemin source ---
    Select Case structType
        Case SIMPLE
            srcPath = ROOT_PATH & "\" & cmbDomaine.Value & "\" & STATUT_A_TRAITER & "\" & fileName
        Case Complex
            srcPath = ROOT_PATH & "\" & cmbDomaine.Value & "\" & cmbSousDomaine.Value & "\" & STATUT_A_TRAITER & "\" & fileName
        Case THREE_LEVEL
            srcPath = ROOT_PATH & "\" & cmbDomaine.Value & "\" & STATUT_A_TRAITER & "\" & cmbSousDomaine.Value & "\" & fileName
        Case DIRCO_SPECIAL
            srcPath = ROOT_PATH & "\" & cmbDomaine.Value & "\" & cmbSousDomaine.Value & "\FICHES CLIENTS\" & STATUT_A_TRAITER & "\" & fileName
    End Select
    
    ' --- Chemin destination (EN COURS) ---
    Select Case structType
        Case SIMPLE
            dstPath = ROOT_PATH & "\" & cmbDomaine.Value & "\" & STATUT_EN_COURS
        Case Complex
            dstPath = ROOT_PATH & "\" & cmbDomaine.Value & "\" & cmbSousDomaine.Value & "\" & STATUT_EN_COURS
        Case THREE_LEVEL
            dstPath = ROOT_PATH & "\" & cmbDomaine.Value & "\" & STATUT_EN_COURS & "\" & cmbSousDomaine.Value
        Case DIRCO_SPECIAL
            dstPath = ROOT_PATH & "\" & cmbDomaine.Value & "\" & cmbSousDomaine.Value & "\FICHES CLIENTS\" & STATUT_EN_COURS
    End Select
    CreateFolderIfNotExists dstPath
    dstPath = dstPath & "\" & fileName
    
    ' --- Déplacement ---
    On Error GoTo ErrorHandler
    Name srcPath As dstPath
    
    ' Log
    LogAction "Déplacement A TRAITER → EN COURS", fileName, cmbDomaine.Value, _
              cmbSousDomaine.Value, txtAgent.Value, txtCommentaire.Value, _
              "De " & STATUT_A_TRAITER & " vers " & STATUT_EN_COURS
    
    ' Rafraîchir
    LoadFichiers
    txtCommentaire.Value = ""
    MsgBox "Fichier déplacé vers " & STATUT_EN_COURS, vbInformation
    Exit Sub
    
ErrorHandler:
    MsgBox "Erreur lors du déplacement : " & Err.Description, vbCritical
End Sub

