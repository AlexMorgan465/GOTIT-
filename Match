Bouton Déplacer (CommandButton2)

Remplace entièrement ton CommandButton2_Click par :

Private Sub CommandButton2_Click()

    On Error GoTo GestionErreur

    Dim FSO As Object
    Dim dossierSource As String
    Dim destinationPath As String
    Dim destinationFinale As String
    Dim nomDossier As String
    Dim fileName As String
    Dim histoPath As String

    Set FSO = CreateObject("Scripting.FileSystemObject")

    ' Vérifier qu'un dossier est sélectionné
    If lstResultats.ListIndex = -1 Then
        MsgBox "Sélectionnez un dossier.", vbExclamation
        Exit Sub
    End If

    fileName = lstResultats.Value
    dossierSource = lstResultats.List(lstResultats.ListIndex, 1)

    nomDossier = FSO.GetFolder(dossierSource).Name

    ' Construction du chemin TRAITES
    Select Case cboRacine.Value

        Case "CONTRATHEQUE"

            destinationPath = ROOT_PATH & "\" & _
                              cboRacine.Value & "\" & _
                              cboSousDossier.Value & "\TRAITES"

        Case "DIRCO", "ACM", "CMO"

            destinationPath = ROOT_PATH & "\" & _
                              cboRacine.Value & "\TRAITES\" & _
                              cboSousDossier.Value

        Case Else

            destinationPath = ROOT_PATH & "\" & _
                              cboRacine.Value & "\TRAITES"

    End Select

    destinationFinale = destinationPath & "\" & nomDossier

    ' Historique
    histoPath = "\\uf11pu01\ACCESSIBILITÉ_CONSEILLERS\ACCESSIBILITE\Historique\" & nomDossier

    ' Vérifier si le dossier existe déjà
    If FSO.FolderExists(destinationFinale) Then

        MsgBox "Le dossier existe déjà dans TRAITES.", vbExclamation
        Exit Sub

    End If

    ' Sauvegarde dans Historique
    FSO.CopyFolder dossierSource, histoPath, True

    ' Déplacement vers TRAITES
    FSO.MoveFolder dossierSource, destinationFinale

    If FSO.FolderExists(destinationFinale) Then

        MsgBox "Dossier déplacé avec succès.", vbInformation

    Else

        MsgBox "Erreur lors du déplacement.", vbCritical
        Exit Sub

    End If

    ' Journalisation
    LoAction "Déplacement", fileName, txtAgent, _
             "de NON CONFORME à TRAITES"

    ' Mise à jour des feuilles
    Dim ws1 As Worksheet
    Dim ws2 As Worksheet
    Dim dict As Object
    Dim lastRow1 As Long
    Dim lastRow2 As Long
    Dim i As Long
    Dim key As String

    Set ws1 = ThisWorkbook.Sheets("SHEET_TRACE_NAME")
    Set ws2 = ThisWorkbook.Sheets("NC_LOG_ACTIONS")

    lastRow1 = ws1.Cells(ws1.Rows.Count, "A").End(xlUp).Row
    lastRow2 = ws2.Cells(ws2.Rows.Count, "C").End(xlUp).Row

    Set dict = CreateObject("Scripting.Dictionary")

    For i = 2 To lastRow2

        key = Trim(ws2.Cells(i, "C").Value)

        If key <> "" Then
            dict(key) = ws2.Cells(i, "A").Value
        End If

    Next i

    For i = 2 To lastRow1

        key = Trim(ws1.Cells(i, "A").Value)

        If dict.Exists(key) Then

            ws1.Cells(i, "H").Value = dict(key)
            ws1.Cells(i, "E").Value = "TRAITES"
            ws1.Cells(i, "K").Value = ws1.Cells(i, "H").Value - ws1.Cells(i, "G").Value

        End If

    Next i

    ' Rafraîchir la liste
    LoadFichiers_NC

    MsgBox "Traitement terminé.", vbInformation

    Exit Sub

GestionErreur:

    MsgBox "Erreur " & Err.Number & vbCrLf & Err.Description, vbCritical

End Sub

Avec cette version, le fonctionnement est :

1. Rechercher → liste les dossiers contenus dans NON CONFORME.


2. Sélection d'un dossier dans lstResultats.


3. Déplacer → copie vers Historique, puis déplace vers TRAITES, met à jour les feuilles Excel et recharge automatiquement la liste.


