Option Explicit

Private Sub UserForm_Initialize()
    ' Lance le scan à l'ouverture du UserForm
    ListerFichiersDossiersFeuilles "\\deks\task"
End Sub

Sub ListerFichiersDossiersFeuilles(CheminRacine As String)
    Dim fso As Object, DossierRacine As Object
    Dim ColDossiersFeuilles As Collection
    
    Set fso = CreateObject("Scripting.FileSystemObject")
    Set ColDossiersFeuilles = New Collection
    
    If Not fso.FolderExists(CheminRacine) Then
        MsgBox "Chemin introuvable : " & CheminRacine, vbCritical
        Exit Sub
    End If
    
    Set DossierRacine = fso.GetFolder(CheminRacine)
    Me.ListBox1.Clear
    Me.ListBox1.AddItem "Scan en cours..."
    
    ' 1. Trouver tous les dossiers qui n'ont pas de sous-dossiers = dossiers feuilles
    TrouverDossiersFeuilles DossierRacine, ColDossiersFeuilles
    
    ' 2. Lister les fichiers de chaque dossier feuille dans la ListBox
    Me.ListBox1.Clear
    If ColDossiersFeuilles.Count = 0 Then
        Me.ListBox1.AddItem "Aucun dossier feuille trouvé"
    Else
        Dim i As Long, Dossier As Object, Fichier As Object
        For i = 1 To ColDossiersFeuilles.Count
            Set Dossier = ColDossiersFeuilles(i)
            Me.ListBox1.AddItem ">>> " & Dossier.Path ' Affiche le nom du dossier
            For Each Fichier In Dossier.Files
                Me.ListBox1.AddItem "    " & Fichier.Name ' Indenté pour les fichiers
            Next Fichier
        Next i
    End If
    
    Set fso = Nothing
    Set DossierRacine = Nothing
    Set ColDossiersFeuilles = Nothing
End Sub

' Fonction récursive qui ne garde que les dossiers sans sous-dossiers
Private Sub TrouverDossiersFeuilles(Dossier As Object, ByRef CollectionResultat As Collection)
    Dim SousDossier As Object
    
    If Dossier.SubFolders.Count = 0 Then
        ' C'est un dossier feuille = pas de sous-dossier
        CollectionResultat.Add Dossier
    Else
        ' Sinon on descend dans chaque sous-dossier
        For Each SousDossier In Dossier.SubFolders
            TrouverDossiersFeuilles SousDossier, CollectionResultat
        Next SousDossier
    End If
End Sub
